# Workmedix ↔ OccuPlus sync agent — configuration
# Copy this file to ".env" (same folder) and fill in the values.

# Run this agent ON the OccuPlus screening laptop. Then OccuPlus is always
# "localhost" — reachable even with NO internet out in the field — and the
# agent uploads to the portal whenever the laptop next gets online.
#   • Agent on the OccuPlus laptop (recommended):   http://localhost:5100
#   • Agent on another PC on the same network:      http://192.168.1.38:5100
OCCUPLUS_URL=http://localhost:5100

# OccuPlus API key (OccuPlus NEO → Settings → API Integration)
OCCUPLUS_KEY=occu-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Your live Workmedix site
WORKMEDIX_URL=https://www.workmedix.com

# Shared secret — must EXACTLY match the SYNC_API_KEY variable set on Railway
SYNC_KEY=choose-a-long-random-secret

# Optional: keep the agent running and re-sync every N minutes.
# Leave at 0 if you schedule it with Windows Task Scheduler instead.
SYNC_INTERVAL_MINUTES=0
