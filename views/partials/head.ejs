<!DOCTYPE html>
<html lang="en-ZA">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta http-equiv="X-UA-Compatible" content="IE=edge">

  <!-- ── Primary SEO ──────────────────────────────────────── -->
  <title><%= title %></title>
  <meta name="description"  content="<%= locals.description || 'Professional workplace health screening services in Johannesburg. Pre-employment medicals, occupational health, drug testing and fitness-for-duty assessments.' %>">
  <meta name="author"       content="Workmedix">
  <meta name="robots"       content="index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1">
  <meta name="keywords"     content="Workmedix, workplace health screening, occupational health, pre-employment medical, drug testing, fitness for duty, HPCSA, Johannesburg, South Africa, occupational health Johannesburg">
  <meta name="theme-color"  content="#2326F2">

  <!-- ── Canonical ────────────────────────────────────────── -->
  <link rel="canonical" href="<%= (locals.APP_URL || 'https://www.workmedix.com') + (locals.canonicalPath || '') %>">

  <!-- ── Open Graph (WhatsApp / Facebook / LinkedIn previews) ── -->
  <meta property="og:type"         content="<%= locals.ogType || 'website' %>">
  <meta property="og:title"        content="<%= title %>">
  <meta property="og:description"  content="<%= locals.description || 'Professional workplace health screening services in Johannesburg. Pre-employment medicals, occupational health, drug testing and fitness-for-duty assessments.' %>">
  <meta property="og:url"          content="<%= (locals.APP_URL || 'https://www.workmedix.com') + (locals.canonicalPath || '') %>">
  <meta property="og:site_name"    content="Workmedix">
  <meta property="og:locale"       content="en_ZA">
  <meta property="og:image"        content="https://www.workmedix.com/images/hero-bg.jpg">
  <meta property="og:image:secure_url" content="https://www.workmedix.com/images/hero-bg.jpg">
  <meta property="og:image:width"  content="1200">
  <meta property="og:image:height" content="630">
  <meta property="og:image:type"   content="image/jpeg">
  <meta property="og:image:alt"    content="Workmedix – Professional Occupational Health Screening">

  <!-- ── Twitter / X Card ─────────────────────────────────── -->
  <meta name="twitter:card"        content="summary_large_image">
  <meta name="twitter:site"        content="@workmedix">
  <meta name="twitter:title"       content="<%= title %>">
  <meta name="twitter:description" content="<%= locals.description || 'Professional workplace health screening services in Johannesburg.' %>">
  <meta name="twitter:image"       content="https://www.workmedix.com/images/hero-bg.jpg">
  <meta name="twitter:image:alt"   content="Workmedix – Occupational Health Screening">

  <!-- ── Geo / Local ──────────────────────────────────────── -->
  <meta name="geo.region"      content="ZA-GP">
  <meta name="geo.placename"   content="Johannesburg, South Africa">
  <meta name="geo.position"    content="-26.2041;28.0473">
  <meta name="ICBM"            content="-26.2041, 28.0473">

  <!-- ── Favicon / PWA ─────────────────────────────────────── -->
  <!-- ?v=2 busts browsers' cache of the old (white-on-transparent, invisible) icon -->
  <link rel="manifest" href="/site.webmanifest">
  <link rel="icon" href="/favicon.ico?v=2" sizes="any">
  <link rel="icon" type="image/png" sizes="48x48"   href="/images/favicon-48.png?v=2">
  <link rel="icon" type="image/png" sizes="192x192" href="/images/favicon-192.png?v=2">
  <link rel="icon" type="image/png" sizes="512x512" href="/images/favicon-512.png?v=2">
  <link rel="apple-touch-icon"                       href="/images/apple-touch-icon.png?v=2">
  <meta name="apple-mobile-web-app-capable"          content="yes">
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
  <meta name="apple-mobile-web-app-title"            content="Workmedix">
  <meta name="application-name"                      content="Workmedix">
  <meta name="msapplication-TileColor"               content="#2326F2">
  <meta name="msapplication-TileImage"               content="/images/favicon-192.png?v=2">

  <!-- ── Performance hints ─────────────────────────────────── -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link rel="preload"    href="/css/style.css?v=<%= locals.assetVersion %>" as="style">
  <link rel="dns-prefetch" href="https://fonts.googleapis.com">

  <!-- ── Fonts ─────────────────────────────────────────────── -->
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Outfit:wght@600;700;800&display=swap" rel="stylesheet">

  <!-- ── Stylesheet ────────────────────────────────────────── -->
  <link rel="stylesheet" href="/css/style.css?v=<%= locals.assetVersion %>">

  <!-- ── JSON-LD Structured Data (homepage only) ───────────── -->
  <% if (locals.page === 'home') { %>
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "MedicalOrganization",
    "name": "Workmedix",
    "alternateName": "Workmedix Occupational Health",
    "url": "https://www.workmedix.com",
    "logo": "https://www.workmedix.com/images/logo.png",
    "image": "https://www.workmedix.com/images/hero-bg.jpg",
    "description": "Professional workplace health screening services in Johannesburg. Pre-employment medicals, occupational health, drug testing and fitness-for-duty assessments.",
    "telephone": "+27747163079",
    "email": "info@workmedix.co.za",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "Johannesburg",
      "addressLocality": "Johannesburg",
      "addressRegion": "Gauteng",
      "addressCountry": "ZA"
    },
    "geo": {
      "@type": "GeoCoordinates",
      "latitude": -26.2041,
      "longitude": 28.0473
    },
    "areaServed": {
      "@type": "Country",
      "name": "South Africa"
    },
    "priceRange": "$$",
    "openingHoursSpecification": {
      "@type": "OpeningHoursSpecification",
      "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday"],
      "opens": "08:00",
      "closes": "17:00"
    },
    "sameAs": ["https://www.workmedix.com"],
    "hasCredential": {
      "@type": "EducationalOccupationalCredential",
      "credentialCategory": "certification",
      "name": "HPCSA Certified Practitioners"
    },
    "serviceType": [
      "Pre-Employment Medical Screening",
      "Occupational Health Assessments",
      "Drug and Alcohol Testing",
      "Fitness for Duty Evaluations",
      "Periodic Medical Examinations"
    ]
  }
  </script>
  <% } %>
</head>
