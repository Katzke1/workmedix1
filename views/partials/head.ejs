<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <!-- Primary SEO -->
  <title><%= title %></title>
  <meta name="description" content="<%= description %>">
  <meta name="robots" content="index, follow">
  <meta name="author" content="Workmedix">
  <meta name="keywords" content="workplace health screening, occupational health, pre-employment medical, drug testing, fitness for duty, Johannesburg, South Africa">

  <!-- Open Graph -->
  <meta property="og:type"        content="website">
  <meta property="og:title"       content="<%= title %>">
  <meta property="og:description" content="<%= description %>">
  <meta property="og:site_name"   content="Workmedix">
  <meta property="og:locale"      content="en_ZA">

  <!-- Twitter Card -->
  <meta name="twitter:card"        content="summary">
  <meta name="twitter:title"       content="<%= title %>">
  <meta name="twitter:description" content="<%= description %>">

  <!-- Geo -->
  <meta name="geo.region"   content="ZA-GP">
  <meta name="geo.placename" content="Johannesburg, South Africa">

  <!-- Google Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">

  <!-- Stylesheet -->
  <link rel="stylesheet" href="/css/style.css">

  <!-- Favicon placeholder -->
  <link rel="icon" type="image/png" href="/images/favicon.png">
</head>
