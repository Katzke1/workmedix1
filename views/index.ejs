<%- include('partials/head') %>
<body>
<%- include('partials/navbar') %>

<!-- ═══════════════════════════════════════════════════════
     HERO
════════════════════════════════════════════════════════ -->
<section class="hero" id="home">
  <div class="hero-overlay"></div>

  <!-- HPCSA badge -->
  <div class="hero-badge">
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
    HPCSA Certified Practitioners
  </div>

  <div class="container">
    <div class="hero-center">

      <!-- Location tag -->
      <div class="location-tag" id="location-tag">
        <span class="location-pulse"></span>
        <span class="location-text">Johannesburg, South Africa</span>
        <span class="location-time"></span>
        <svg class="location-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="12" height="12"><path d="M4.5 19.5l15-15m0 0H8.25m11.25 0v11.25"/></svg>
      </div>

      <!-- Headline with rotating word -->
      <h1 class="hero-title">
        Keeping your workforce<br>
        <span class="hero-word" id="hero-rotating-word">trusted</span>
      </h1>

      <p class="hero-sub">
        Workmedix delivers comprehensive occupational health screenings for corporate,
        mining, and construction businesses across Johannesburg — fast, compliant, and
        professional every step of the way.
      </p>

      <div class="hero-actions">
        <a href="#contact" class="btn btn-primary btn-lg">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
          Book a Screening
        </a>
        <a href="#services" class="btn btn-outline-white btn-lg">Our Services &darr;</a>
      </div>

      <div class="hero-stats">
        <div class="hero-stat-item">
          <span class="hero-stat-num">HPCSA</span>
          <span class="hero-stat-lbl">Compliant</span>
        </div>
        <div class="hero-stat-divider"></div>
        <div class="hero-stat-item">
          <span class="hero-stat-num">24h</span>
          <span class="hero-stat-lbl">Turnaround</span>
        </div>
        <div class="hero-stat-divider"></div>
        <div class="hero-stat-item">
          <span class="hero-stat-num">JHB</span>
          <span class="hero-stat-lbl">Wide Coverage</span>
        </div>
        <div class="hero-stat-divider"></div>
        <div class="hero-stat-item">
          <span class="hero-stat-num">4+</span>
          <span class="hero-stat-lbl">Services</span>
        </div>
      </div>

    </div>
  </div>
</section>

<!-- ═══════════════════════════════════════════════════════
     ABOUT
════════════════════════════════════════════════════════ -->
<section class="bg-white" id="about">
  <div class="container">
    <div class="about-grid">
      <div>
        <span class="section-label">About Workmedix</span>
        <h2 class="section-title">Your Trusted Occupational Health Partner</h2>
        <p style="font-size:1.05rem;margin-bottom:1.25rem;">
          Workmedix is a Johannesburg-based occupational health service provider
          dedicated to helping businesses meet their legal and ethical obligations
          when it comes to employee health and safety.
        </p>
        <p>
          Our team of HPCSA-registered practitioners brings clinical expertise and
          industry knowledge to every engagement — whether you need a single pre-employment
          medical or a full-scale occupational health programme for hundreds of employees.
        </p>
        <a href="#contact" class="btn btn-outline-dark mt-3">Get in Touch</a>
      </div>
      <div>
        <div class="about-values">
          <div class="value-item">
            <div class="value-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            </div>
            <div>
              <h4>Clinical Accuracy</h4>
              <p>Precision-driven assessments with thorough documentation and reporting.</p>
            </div>
          </div>
          <div class="value-item">
            <div class="value-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            </div>
            <div>
              <h4>Regulatory Compliance</h4>
              <p>Fully compliant with OHS Act, HPCSA guidelines, and industry regulations.</p>
            </div>
          </div>
          <div class="value-item">
            <div class="value-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            </div>
            <div>
              <h4>Fast Turnaround</h4>
              <p>Same-day results where possible. Full reports within 24–48 hours.</p>
            </div>
          </div>
          <div class="value-item">
            <div class="value-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
            </div>
            <div>
              <h4>Professionalism</h4>
              <p>Courteous, confidential, and professional at every touchpoint.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ═══════════════════════════════════════════════════════
     SERVICES
════════════════════════════════════════════════════════ -->
<section class="bg-grey" id="services">
  <div class="container text-center">
    <span class="section-label">What We Offer</span>
    <h2 class="section-title">Our Services</h2>
    <p class="section-desc">Comprehensive workplace health solutions designed to keep your workforce healthy, safe, and legally compliant.</p>

    <div class="services-grid">
      <!-- Pre-employment -->
      <div class="service-card">
        <div class="service-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2"/>
            <rect x="9" y="3" width="6" height="4" rx="2"/><line x1="9" y1="12" x2="15" y2="12"/><line x1="9" y1="16" x2="13" y2="16"/>
          </svg>
        </div>
        <h3>Pre-employment Medicals</h3>
        <p>Comprehensive pre-placement assessments ensuring candidates are physically and cognitively fit for their designated roles, meeting all HPCSA and industry requirements before onboarding.</p>
      </div>

      <!-- Occupational Health -->
      <div class="service-card">
        <div class="service-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/>
          </svg>
        </div>
        <h3>Occupational Health Screenings</h3>
        <p>Periodic health assessments for employees in compliance with OHS Act requirements — identifying occupational health risks and monitoring the effects of workplace exposure over time.</p>
      </div>

      <!-- Drug & Alcohol -->
      <div class="service-card">
        <div class="service-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M9 3h6l1 7H8L9 3zM8 10c0 5 4 8 4 11M16 10c0 5-4 8-4 11"/>
          </svg>
        </div>
        <h3>Drug &amp; Alcohol Testing</h3>
        <p>SAMSA-compliant rapid drug and alcohol screening with certified chain-of-custody documentation — supporting your workplace substance abuse policy and safety programme.</p>
      </div>

      <!-- Fitness for Duty -->
      <div class="service-card">
        <div class="service-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M18 8h1a4 4 0 010 8h-1"/><path d="M2 8h16v9a4 4 0 01-4 4H6a4 4 0 01-4-4V8z"/>
            <line x1="6" y1="1" x2="6" y2="4"/><line x1="10" y1="1" x2="10" y2="4"/><line x1="14" y1="1" x2="14" y2="4"/>
          </svg>
        </div>
        <h3>Fitness for Duty Assessments</h3>
        <p>Thorough evaluations of an employee's physical and mental fitness to safely perform their specific job functions — critical for safety-critical roles in mining, construction, and heavy industry.</p>
      </div>
    </div>
  </div>
</section>

<!-- ═══════════════════════════════════════════════════════
     WHO WE SERVE
════════════════════════════════════════════════════════ -->
<section class="bg-white" id="serve">
  <div class="container text-center">
    <span class="section-label">Who We Serve</span>
    <h2 class="section-title">Built for Your Industry</h2>
    <p class="section-desc">We work with organisations of all sizes that take employee health and safety seriously.</p>

    <div class="serve-grid" style="max-width:860px;margin:0 auto;">
      <div class="serve-card" style="text-align:left;">
        <div class="serve-card-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 7V5a2 2 0 00-2-2h-4a2 2 0 00-2 2v2"/>
            <line x1="12" y1="12" x2="12" y2="16"/><line x1="10" y1="14" x2="14" y2="14"/>
          </svg>
        </div>
        <h3>Corporate Companies &amp; HR Departments</h3>
        <p>We partner with HR teams and occupational health managers across Johannesburg to implement and manage comprehensive health screening programmes for your entire workforce — from executives to factory floor staff.</p>
        <ul style="margin-top:1rem;padding-left:1.2rem;list-style:disc;color:var(--text-light);font-size:.9rem;">
          <li>Scalable programmes for any company size</li>
          <li>Streamlined reporting for HR compliance records</li>
          <li>Flexible on-site or clinic-based delivery</li>
        </ul>
      </div>
      <div class="serve-card" style="text-align:left;">
        <div class="serve-card-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
          </svg>
        </div>
        <h3>Mining &amp; Construction Industries</h3>
        <p>Specialised fitness-for-duty and pre-employment screenings tailored to the rigorous physical demands and strict regulatory requirements of South Africa's mining and construction sectors.</p>
        <ul style="margin-top:1rem;padding-left:1.2rem;list-style:disc;color:var(--text-light);font-size:.9rem;">
          <li>MHSA and OHS Act compliant medicals</li>
          <li>High-volume site mobilisation screenings</li>
          <li>Audiometry, spirometry, and vision testing</li>
        </ul>
      </div>
    </div>
  </div>
</section>

<!-- ═══════════════════════════════════════════════════════
     WHY WORKMEDIX
════════════════════════════════════════════════════════ -->
<section class="bg-primary" id="why">
  <div class="container text-center">
    <span class="section-label" style="color:rgba(255,255,255,.6);">Why Choose Us</span>
    <h2 style="color:var(--white);margin-bottom:.75rem;">The Workmedix Difference</h2>
    <p style="color:rgba(255,255,255,.65);max-width:580px;margin:0 auto;">We combine clinical excellence with operational efficiency so you never have to choose between quality and speed.</p>

    <div class="why-grid">
      <div class="why-item">
        <div class="why-num">1</div>
        <div>
          <h4>HPCSA-Compliant Practitioners</h4>
          <p>All healthcare professionals are registered with the Health Professions Council of South Africa, ensuring the highest clinical and ethical standards.</p>
        </div>
      </div>
      <div class="why-item">
        <div class="why-num">2</div>
        <div>
          <h4>Fast, Reliable Turnaround</h4>
          <p>Same-day verbal results where possible. Comprehensive written reports delivered within 24–48 hours so your hiring process never stalls.</p>
        </div>
      </div>
      <div class="why-item">
        <div class="why-num">3</div>
        <div>
          <h4>On-Site &amp; Clinic-Based Testing</h4>
          <p>We come to your site or you visit our clinic — flexible service delivery designed around your operational needs.</p>
        </div>
      </div>
      <div class="why-item">
        <div class="why-num">4</div>
        <div>
          <h4>Johannesburg-Wide Coverage</h4>
          <p>Serving all areas of Johannesburg and the broader Gauteng region, including East Rand, West Rand, Soweto, Midrand, and surrounds.</p>
        </div>
      </div>
      <div class="why-item">
        <div class="why-num">5</div>
        <div>
          <h4>Comprehensive Documentation</h4>
          <p>Detailed, audit-ready reports and certificates stored securely in our client portal — accessible by your HR team whenever needed.</p>
        </div>
      </div>
      <div class="why-item">
        <div class="why-num">6</div>
        <div>
          <h4>Strict Medical Confidentiality</h4>
          <p>All health data is handled with the utmost discretion in compliance with the National Health Act and POPIA regulations.</p>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ═══════════════════════════════════════════════════════
     CONTACT
════════════════════════════════════════════════════════ -->
<section class="bg-grey" id="contact">
  <div class="container">
    <div class="text-center" style="margin-bottom:3.5rem;">
      <span class="section-label">Get in Touch</span>
      <h2 class="section-title">Book a Screening or Send an Enquiry</h2>
      <p>Ready to get started? Fill in the form below and our team will be in touch within one business day.</p>
    </div>

    <div class="contact-grid">
      <!-- Info side -->
      <div>
        <h3>Contact Details</h3>
        <div class="contact-detail">
          <svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 9.81a19.79 19.79 0 01-3.07-8.68A2 2 0 012 .82h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L6.09 8.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
          <div>
            <strong>Phone</strong>
            <!-- TODO: Replace with real phone number -->
            <span>+27 (0)11 000 0000</span>
          </div>
        </div>
        <div class="contact-detail">
          <svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
          <div>
            <strong>Email</strong>
            <!-- TODO: Replace with real email address -->
            <span>info@workmedix.co.za</span>
          </div>
        </div>
        <div class="contact-detail">
          <svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
          <div>
            <strong>Office Hours</strong>
            <span>Monday – Friday: 07:30 – 17:00</span>
          </div>
        </div>
        <div class="contact-detail">
          <svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
          <div>
            <strong>Location</strong>
            <!-- TODO: Replace with real address -->
            <span>Johannesburg, Gauteng, South Africa</span>
          </div>
        </div>
        <!-- TODO: Replace with a real Google Maps embed -->
        <div class="map-placeholder">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" width="28" height="28" style="margin-bottom:.5rem;color:var(--mid-grey);"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
          <span style="display:block;font-size:.85rem;color:var(--mid-grey);">Map coming soon</span>
          <span style="display:block;font-size:.78rem;color:var(--mid-grey);margin-top:.25rem;">Johannesburg, Gauteng, South Africa</span>
        </div>
      </div>

      <!-- Form side -->
      <div class="contact-form-wrap">
        <h3>Send Us a Message</h3>
        <form id="contact-form" novalidate>
          <div class="form-row">
            <div class="form-group">
              <label class="form-label" for="c-name">Full Name *</label>
              <input type="text" id="c-name" class="form-control" placeholder="Jane Smith" required>
            </div>
            <div class="form-group">
              <label class="form-label" for="c-company">Company</label>
              <input type="text" id="c-company" class="form-control" placeholder="Acme Corp">
            </div>
          </div>
          <div class="form-row">
            <div class="form-group">
              <label class="form-label" for="c-email">Email Address *</label>
              <input type="email" id="c-email" class="form-control" placeholder="jane@company.co.za" required>
            </div>
            <div class="form-group">
              <label class="form-label" for="c-phone">Phone Number *</label>
              <input type="tel" id="c-phone" class="form-control" placeholder="+27 82 000 0000" required>
            </div>
          </div>
          <div class="form-group">
            <label class="form-label" for="c-service">Service Required *</label>
            <select id="c-service" class="form-control" required>
              <option value="">— Select a service —</option>
              <option>Pre-employment Medicals</option>
              <option>Occupational Health Screenings</option>
              <option>Drug &amp; Alcohol Testing</option>
              <option>Fitness for Duty Assessments</option>
              <option>Multiple / Not sure yet</option>
            </select>
          </div>
          <div class="form-group">
            <label class="form-label" for="c-message">Message *</label>
            <textarea id="c-message" class="form-control" rows="4" placeholder="Tell us about your requirements, number of employees, preferred dates…" required></textarea>
          </div>
          <button type="submit" class="btn btn-primary btn-block">Send Message →</button>
        </form>
        <div id="contact-success">
          <div class="success-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
          </div>
          <h3>Message Sent!</h3>
          <p>Thank you for getting in touch. A member of our team will respond within one business day.</p>
        </div>
      </div>
    </div>
  </div>
</section>

<%- include('partials/footer') %>

<script src="/js/main.js"></script>
</body>
</html>
