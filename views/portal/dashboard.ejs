<%- include('../partials/head') %>
<body>
<div class="app-body">
<%- include('../partials/portal-sidebar') %>
<main class="app-main">
  <div class="app-topbar">
    <div class="app-topbar-title">
      <h2>Dashboard</h2>
      <p>Welcome back, <%= user.name.split(' ')[0] %></p>
    </div>
    <div class="topbar-actions">
      <a href="/portal/book" class="btn btn-primary btn-sm">+ Book Screening</a>
    </div>
  </div>

  <div class="app-content">
    <!-- Welcome banner -->
    <div class="dash-welcome-banner">
      <div class="dash-welcome-logo">
        <img src="/images/logo.png" alt="Workmedix">
      </div>
      <div class="dash-welcome-text">
        <h3>Good day, <%= user.name.split(' ')[0] %>!</h3>
        <p><% if (user.company_name) { %><%= user.company_name %> &nbsp;·&nbsp; <% } %>Workmedix Client Portal</p>
      </div>
    </div>

    <!-- Stats -->
    <div class="stats-grid">
      <div class="stat-card">
        <div class="stat-icon blue">
          <svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
        </div>
        <div>
          <div class="stat-num"><%= stats.upcoming %></div>
          <div class="stat-label">Upcoming Bookings</div>
        </div>
      </div>
      <div class="stat-card">
        <div class="stat-icon green">
          <svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
        </div>
        <div>
          <div class="stat-num"><%= stats.results %></div>
          <div class="stat-label">Available Results</div>
        </div>
      </div>
      <div class="stat-card">
        <div class="stat-icon purple">
          <svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="6"/><path d="M15.477 12.89L17 22l-5-3-5 3 1.523-9.11"/></svg>
        </div>
        <div>
          <div class="stat-num"><%= stats.certificates %></div>
          <div class="stat-label">Certificates</div>
        </div>
      </div>
      <div class="stat-card">
        <div class="stat-icon amber">
          <svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
        </div>
        <div>
          <div class="stat-num" style="font-size:1.1rem;padding-top:.2rem;"><%= user.company_name || '—' %></div>
          <div class="stat-label">Organisation</div>
        </div>
      </div>
    </div>

    <!-- Recent bookings -->
    <div class="card">
      <div class="card-header">
        <h3>Recent Bookings</h3>
        <a href="/portal/bookings" style="font-size:.85rem;color:var(--accent);">View all →</a>
      </div>
      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th>Service</th>
              <th>Preferred Date</th>
              <th>Status</th>
              <th>Submitted</th>
            </tr>
          </thead>
          <tbody>
            <% if (recentBookings.length === 0) { %>
              <tr><td class="table-empty" colspan="4">No bookings yet. <a href="/portal/book">Book your first screening →</a></td></tr>
            <% } else { recentBookings.forEach(b => { %>
              <tr>
                <td><strong><%= b.service_type %></strong></td>
                <td><%= b.preferred_date %></td>
                <td><span class="badge badge-<%= b.status %>"><%= b.status %></span></td>
                <td style="color:var(--mid-grey);font-size:.85rem;"><%= new Date(b.created_at).toLocaleDateString('en-ZA') %></td>
              </tr>
            <% }) } %>
          </tbody>
        </table>
      </div>
      <div class="card-footer" style="text-align:center;">
        <a href="/portal/book" class="btn btn-primary btn-sm">+ Request New Booking</a>
      </div>
    </div>

    <!-- Quick actions -->
    <div class="grid-3" style="margin-top:1.5rem;">
      <a href="/portal/results" class="quick-action-card">
        <div class="quick-action-icon" style="background:linear-gradient(135deg,#0c2461,#2e86de);">
          <svg viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="26" height="26"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
        </div>
        <h4>My Results</h4>
        <p>View &amp; download screening results</p>
      </a>
      <a href="/portal/certificates" class="quick-action-card">
        <div class="quick-action-icon" style="background:linear-gradient(135deg,#0b6e4f,#00b894);">
          <svg viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="26" height="26"><circle cx="12" cy="8" r="6"/><path d="M15.477 12.89L17 22l-5-3-5 3 1.523-9.11"/></svg>
        </div>
        <h4>My Certificates</h4>
        <p>Download issued health certificates</p>
      </a>
      <a href="/portal/profile" class="quick-action-card">
        <div class="quick-action-icon" style="background:linear-gradient(135deg,#6c5ce7,#a29bfe);">
          <svg viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="26" height="26"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
        </div>
        <h4>My Profile</h4>
        <p>Update account settings &amp; password</p>
      </a>
    </div>
  </div>
</main>
</div>
<script src="/js/main.js"></script>
</body>
</html>
