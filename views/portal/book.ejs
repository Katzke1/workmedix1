<%- include('../partials/head') %>
<body>
<div class="app-body">
<%- include('../partials/portal-sidebar') %>
<main class="app-main">
  <div class="app-topbar">
    <div class="app-topbar-title">
      <h2>Book a Screening</h2>
      <p>Request a new appointment</p>
    </div>
  </div>

  <div class="app-content">
    <div style="max-width:680px;">
      <% if (error) { %>
        <div class="alert alert-danger"><%= error %></div>
      <% } %>
      <% if (success) { %>
        <div class="alert alert-success" data-autodismiss><%= success %></div>
      <% } %>

      <div class="card">
        <div class="card-header">
          <h3>Screening Request Form</h3>
        </div>
        <div class="card-body">
          <p style="margin-bottom:1.5rem;font-size:.92rem;">
            Complete the form below to request an appointment. Our team will review
            your request and confirm your booking within one business day.
          </p>

          <form method="POST" action="/portal/book">
            <div class="form-group">
              <label class="form-label" for="service_type">Service Type *</label>
              <select id="service_type" name="service_type" class="form-control" required>
                <option value="">— Select a service —</option>
                <option>Pre-employment Medicals</option>
                <option>Occupational Health Screenings</option>
                <option>Drug &amp; Alcohol Testing</option>
                <option>Fitness for Duty Assessments</option>
              </select>
            </div>
            <div class="form-group">
              <label class="form-label" for="preferred_date">Preferred Date *</label>
              <input type="date" id="preferred_date" name="preferred_date" class="form-control"
                     min="<%= new Date().toISOString().split('T')[0] %>" required>
              <span class="upload-hint">We will confirm the exact appointment date and time by email.</span>
            </div>
            <div class="form-group">
              <div style="display:flex;justify-content:space-between;align-items:center;">
                <label class="form-label" for="notes" style="margin-bottom:0;">Additional Notes</label>
                <span id="notes-counter" style="font-size:.78rem;color:var(--mid-grey);">0 / 500</span>
              </div>
              <textarea id="notes" name="notes" class="form-control" rows="4" maxlength="500"
                        placeholder="Number of employees, specific requirements, location preferences…"></textarea>
            </div>
            <button type="submit" class="btn btn-primary" id="book-btn">Submit Booking Request →</button>
          </form>
        </div>
      </div>

      <div class="card" style="margin-top:1.5rem;border-left:3px solid var(--accent);">
        <div class="card-body" style="display:flex;gap:1.25rem;align-items:flex-start;">
          <div style="flex-shrink:0;width:38px;height:38px;border-radius:10px;background:linear-gradient(135deg,var(--primary),var(--accent));display:flex;align-items:center;justify-content:center;">
            <svg viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" width="18" height="18"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
          </div>
          <div>
            <h4 style="color:var(--primary);margin-bottom:.5rem;">What happens next?</h4>
            <ol style="padding-left:1.2rem;color:var(--text-light);font-size:.9rem;line-height:1.9;">
              <li>Your request is logged and assigned to our scheduling team.</li>
              <li>We confirm your appointment date, time, and location via email.</li>
              <li>After your screening, results are uploaded to your portal within 24–48 hours.</li>
              <li>Certificates are issued upon completion and review.</li>
            </ol>
          </div>
        </div>
      </div>
    </div>
  </div>
</main>
</div>
<script src="/js/main.js"></script>
</body>
</html>
