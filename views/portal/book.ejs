<%- include('../partials/head') %>
<body>
<div class="app-body">
  <%- include('../partials/portal-sidebar') %>
  <main class="app-main">
    <div class="app-topbar">
      <div class="app-topbar-title">
        <h2>Book a Screening</h2>
        <p>Complete the steps below to request a mobile screening appointment</p>
      </div>
    </div>

    <div class="app-content">
      <div style="max-width:720px;">
        <% if (locals.error)   { %><div class="alert alert-danger"><%= error %></div><% } %>
        <% if (locals.success) { %><div class="alert alert-success"><%= success %></div><% } %>

        <!-- Step progress bar -->
        <div class="booking-steps" id="booking-steps">
          <div class="booking-step active" data-step="1">
            <div class="step-dot">1</div><span>Service &amp; Date</span>
          </div>
          <div class="booking-step" data-step="2">
            <div class="step-dot">2</div><span>Location</span>
          </div>
          <div class="booking-step" data-step="3">
            <div class="step-dot">3</div><span>Employees</span>
          </div>
          <div class="booking-step" data-step="4">
            <div class="step-dot">4</div><span>Review</span>
          </div>
        </div>

        <form method="POST" action="/portal/book" id="booking-form">
          <%- include('../partials/csrf') %>

          <!-- ── Step 1: Service & Date ─────────────────────────────────────── -->
          <div class="book-panel active" id="step-1">
            <div class="card">
              <div class="card-header"><h3>Step 1 — Service &amp; Date</h3></div>
              <div class="card-body">
                <div class="form-group">
                  <label class="form-label">Service Type *</label>
                  <div class="service-grid">
                    <% services.forEach(svc => { %>
                    <label class="service-card">
                      <input type="radio" name="service_id" value="<%= svc.id %>" data-name="<%= svc.service_name %>" required>
                      <div class="service-card-inner">
                        <strong><%= svc.service_name %></strong>
                        <span>R<%= svc.default_price.toLocaleString() %> per person</span>
                      </div>
                    </label>
                    <% }) %>
                  </div>
                </div>
                <div class="form-row">
                  <div class="form-group">
                    <label class="form-label">Preferred Date *</label>
                    <input type="date" name="preferred_date" class="form-control"
                           min="<%= new Date().toISOString().split('T')[0] %>" required>
                    <span class="form-hint">We will confirm the exact time by email.</span>
                  </div>
                  <div class="form-group">
                    <label class="form-label">Preferred Time</label>
                    <select name="preferred_time" class="form-control">
                      <option value="">— Any time —</option>
                      <option>07:00</option><option>08:00</option><option>09:00</option>
                      <option>10:00</option><option>11:00</option><option>13:00</option>
                      <option>14:00</option>
                    </select>
                  </div>
                </div>
                <div class="form-group">
                  <label class="form-label">Additional Notes</label>
                  <textarea name="notes" class="form-control" rows="3" maxlength="500"
                            placeholder="Special requirements, access instructions…"></textarea>
                </div>
                <button type="button" class="btn btn-primary" onclick="goStep(2)">Next: Location →</button>
              </div>
            </div>
          </div>

          <!-- ── Step 2: Location / Site ────────────────────────────────────── -->
          <div class="book-panel hidden" id="step-2">
            <div class="card">
              <div class="card-header"><h3>Step 2 — Screening Location</h3></div>
              <div class="card-body">
                <% if (sites.length > 0) { %>
                <p style="margin-bottom:1rem;font-size:.92rem;color:var(--ink-muted);">Select a saved site or enter a new one.</p>
                <div class="form-group">
                  <label class="form-label">Saved Sites</label>
                  <div style="display:flex;flex-direction:column;gap:.5rem;" id="site-list">
                    <% sites.forEach(site => { %>
                    <label class="site-option">
                      <input type="radio" name="site_id" value="<%= site.id %>" onchange="hideSiteForm()">
                      <div class="site-option-inner">
                        <strong><%= site.label %></strong>
                        <span><%= site.address %><% if (site.city) { %>, <%= site.city %><% } %></span>
                      </div>
                    </label>
                    <% }) %>
                    <label class="site-option">
                      <input type="radio" name="site_id" value="new" onchange="showSiteForm()">
                      <div class="site-option-inner">
                        <strong>+ New location</strong>
                        <span>Enter a new screening address</span>
                      </div>
                    </label>
                  </div>
                </div>
                <% } %>

                <!-- New site form (shown when "new" selected or no sites exist) -->
                <div id="new-site-form" class="<%= sites.length > 0 ? 'hidden' : '' %>"
                     style="border-top:<%= sites.length > 0 ? '1px solid var(--border)' : 'none' %>;padding-top:<%= sites.length > 0 ? '1rem' : '0' %>;margin-top:<%= sites.length > 0 ? '1rem' : '0' %>;">
                  <p style="font-size:.88rem;color:var(--ink-muted);margin-bottom:1rem;">
                    This site will be saved to your company's locations for future bookings.
                  </p>
                  <div class="form-group">
                    <label class="form-label">Site Label *</label>
                    <input type="text" name="new_site_label" class="form-control" placeholder="e.g. Head Office, Mine Site A">
                  </div>
                  <div class="form-group">
                    <label class="form-label">Street Address *</label>
                    <input type="text" name="new_site_address" class="form-control" placeholder="123 Main Street">
                  </div>
                  <div class="form-row">
                    <div class="form-group">
                      <label class="form-label">City</label>
                      <input type="text" name="new_site_city" class="form-control" placeholder="Johannesburg">
                    </div>
                    <div class="form-group">
                      <label class="form-label">Province</label>
                      <select name="new_site_province" class="form-control">
                        <option value="">— Select —</option>
                        <option>Gauteng</option><option>Western Cape</option><option>KwaZulu-Natal</option>
                        <option>Eastern Cape</option><option>Limpopo</option><option>Mpumalanga</option>
                        <option>North West</option><option>Free State</option><option>Northern Cape</option>
                      </select>
                    </div>
                  </div>
                  <div class="form-row">
                    <div class="form-group">
                      <label class="form-label">Site Contact Name</label>
                      <input type="text" name="new_site_contact_name" class="form-control" placeholder="John Smith">
                    </div>
                    <div class="form-group">
                      <label class="form-label">Site Contact Phone</label>
                      <input type="tel" name="new_site_contact_phone" class="form-control" placeholder="011 000 0000">
                    </div>
                  </div>
                </div>

                <div style="display:flex;gap:.75rem;margin-top:.5rem;">
                  <button type="button" class="btn btn-outline-dark" onclick="goStep(1)">← Back</button>
                  <button type="button" class="btn btn-primary" onclick="goStep(3)">Next: Employees →</button>
                </div>
              </div>
            </div>
          </div>

          <!-- ── Step 3: Employees ───────────────────────────────────────────── -->
          <div class="book-panel hidden" id="step-3">
            <div class="card">
              <div class="card-header">
                <h3>Step 3 — Select Employees</h3>
                <span id="emp-count-label" style="font-size:.85rem;color:var(--ink-muted);">0 selected</span>
              </div>
              <div class="card-body">
                <% if (employees.length === 0) { %>
                <div class="alert" style="background:var(--surface-2);border:1px solid var(--border);border-radius:8px;padding:1rem;">
                  <strong>No employees in your roster.</strong>
                  <a href="/portal/employees">Add employees first</a> to include them in this booking.
                </div>
                <% } else { %>
                <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:1rem;">
                  <input type="text" id="emp-search" class="form-control" placeholder="Search employees…"
                         style="width:240px;" oninput="filterEmployees(this.value)">
                  <div style="display:flex;gap:.5rem;">
                    <button type="button" class="btn btn-outline-dark btn-sm" onclick="selectAllEmps(true)">Select All</button>
                    <button type="button" class="btn btn-outline-dark btn-sm" onclick="selectAllEmps(false)">Clear</button>
                  </div>
                </div>
                <div class="employee-checklist" id="employee-list">
                  <% employees.forEach(emp => { %>
                  <label class="emp-check-row" data-name="<%= (emp.first_name + ' ' + emp.last_name + ' ' + (emp.job_title||'')).toLowerCase() %>">
                    <input type="checkbox" name="employee_ids[]" value="<%= emp.id %>" onchange="countEmps()">
                    <div class="emp-check-info">
                      <div style="display:flex;align-items:center;gap:.6rem;">
                        <div style="width:32px;height:32px;background:var(--primary);border-radius:50%;display:flex;align-items:center;justify-content:center;font-weight:700;font-size:.8rem;color:white;flex-shrink:0;">
                          <%= emp.first_name.charAt(0).toUpperCase() %>
                        </div>
                        <div>
                          <strong><%= emp.first_name %> <%= emp.last_name %></strong>
                          <div style="font-size:.8rem;color:var(--ink-muted);"><%= emp.job_title || 'Employee' %></div>
                        </div>
                      </div>
                    </div>
                    <span style="font-size:.78rem;color:var(--ink-muted)"><%= emp.id_number || 'No ID' %></span>
                  </label>
                  <% }) %>
                </div>
                <% } %>

                <div style="display:flex;gap:.75rem;margin-top:1rem;">
                  <button type="button" class="btn btn-outline-dark" onclick="goStep(2)">← Back</button>
                  <button type="button" class="btn btn-primary" onclick="goStep(4)">Next: Review →</button>
                </div>
              </div>
            </div>
          </div>

          <!-- ── Step 4: Review & Submit ─────────────────────────────────────── -->
          <div class="book-panel hidden" id="step-4">
            <div class="card">
              <div class="card-header"><h3>Step 4 — Review &amp; Submit</h3></div>
              <div class="card-body">
                <div id="review-summary" style="background:var(--surface-2);border:1px solid var(--border);border-radius:10px;padding:1.25rem;margin-bottom:1.5rem;font-size:.92rem;line-height:2;">
                  <div><strong>Service:</strong> <span id="rev-service">—</span></div>
                  <div><strong>Preferred Date:</strong> <span id="rev-date">—</span></div>
                  <div><strong>Preferred Time:</strong> <span id="rev-time">—</span></div>
                  <div><strong>Location:</strong> <span id="rev-site">—</span></div>
                  <div><strong>Employees:</strong> <span id="rev-emps">—</span></div>
                </div>
                <p style="font-size:.88rem;color:var(--ink-muted);margin-bottom:1.25rem;">
                  Once submitted, our scheduling team will review your request and confirm within one business day.
                </p>
                <div style="display:flex;gap:.75rem;">
                  <button type="button" class="btn btn-outline-dark" onclick="goStep(3)">← Back</button>
                  <button type="submit" class="btn btn-primary">Submit Booking Request →</button>
                </div>
              </div>
            </div>
          </div>

        </form>

        <!-- Info card -->
        <div class="card" style="margin-top:1.25rem;border-left:3px solid var(--accent);">
          <div class="card-body" style="display:flex;gap:1rem;align-items:flex-start;">
            <div style="flex-shrink:0;width:38px;height:38px;border-radius:10px;background:linear-gradient(135deg,var(--primary),var(--accent));display:flex;align-items:center;justify-content:center;">
              <svg viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" width="18" height="18"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
            </div>
            <div>
              <h4 style="color:var(--primary);margin-bottom:.5rem;">What happens next?</h4>
              <ol style="padding-left:1.2rem;color:var(--text-light);font-size:.9rem;line-height:1.9;">
                <li>Your request is logged and assigned to our scheduling team.</li>
                <li>We confirm your appointment date, time, and location via email.</li>
                <li>After your screening, results are uploaded to your portal within 24–48 hours.</li>
                <li>Certificates are issued upon completion and review.</li>
              </ol>
            </div>
          </div>
        </div>
      </div>
    </div>
  </main>
</div>

<style>
/* ── Booking step progress ─────────── */
.booking-steps { display:flex; gap:0; margin-bottom:1.75rem; }
.booking-step  { flex:1; display:flex; align-items:center; gap:.6rem; padding:.75rem 1rem; background:var(--surface-2); border:1px solid var(--border); font-size:.85rem; color:var(--ink-muted); font-weight:500; position:relative; }
.booking-step:not(:last-child)::after { content:''; position:absolute; right:-1px; top:50%; transform:translateY(-50%); width:0; height:0; border-top:14px solid transparent; border-bottom:14px solid transparent; border-left:14px solid var(--border); z-index:2; }
.booking-step.active { background:var(--primary); color:white; border-color:var(--primary); }
.booking-step.active::after { border-left-color:var(--primary); }
.booking-step.done { background:var(--surface-2); color:var(--primary); border-color:var(--border); }
.step-dot { width:24px; height:24px; border-radius:50%; background:rgba(255,255,255,.25); display:flex; align-items:center; justify-content:center; font-weight:700; font-size:.78rem; flex-shrink:0; }
.booking-step:not(.active) .step-dot { background:var(--border); color:var(--ink-muted); }
.booking-step.done .step-dot { background:var(--primary); color:white; }

/* ── Service cards ────────────────── */
.service-grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(200px,1fr)); gap:.75rem; }
.service-card input[type="radio"] { display:none; }
.service-card-inner { border:2px solid var(--border); border-radius:10px; padding:1rem; cursor:pointer; transition:border-color .15s, background .15s; display:flex; flex-direction:column; gap:.25rem; }
.service-card-inner strong { font-size:.92rem; color:var(--ink); }
.service-card-inner span { font-size:.82rem; color:var(--ink-muted); }
.service-card input[type="radio"]:checked + .service-card-inner { border-color:var(--primary); background:rgba(35,38,242,.05); }

/* ── Site option ──────────────────── */
.site-option { display:block; cursor:pointer; }
.site-option input { display:none; }
.site-option-inner { border:2px solid var(--border); border-radius:10px; padding:.85rem 1rem; display:flex; flex-direction:column; gap:.2rem; transition:border-color .15s, background .15s; }
.site-option-inner strong { font-size:.9rem; }
.site-option-inner span { font-size:.82rem; color:var(--ink-muted); }
.site-option input:checked + .site-option-inner { border-color:var(--primary); background:rgba(35,38,242,.05); }

/* ── Employee checklist ───────────── */
.employee-checklist { display:flex; flex-direction:column; gap:.4rem; max-height:340px; overflow-y:auto; border:1px solid var(--border); border-radius:10px; padding:.5rem; }
.emp-check-row { display:flex; align-items:center; justify-content:space-between; gap:1rem; padding:.6rem .75rem; border-radius:8px; cursor:pointer; transition:background .12s; }
.emp-check-row input { margin-right:.5rem; accent-color:var(--primary); width:16px; height:16px; flex-shrink:0; }
.emp-check-row:hover { background:var(--surface-2); }
.emp-check-row input:checked ~ .emp-check-info { color:var(--primary); }
.emp-check-info { flex:1; }

.book-panel.hidden { display:none; }
.form-hint { font-size:.8rem; color:var(--ink-muted); }
</style>

<script>
function goStep(n) {
  document.querySelectorAll('.book-panel').forEach((p, i) => {
    p.classList.toggle('hidden', i + 1 !== n);
  });
  document.querySelectorAll('.booking-step').forEach((s, i) => {
    s.classList.remove('active', 'done');
    if (i + 1 === n) s.classList.add('active');
    if (i + 1 < n)  s.classList.add('done');
  });
  if (n === 4) buildReview();
}

function showSiteForm() { document.getElementById('new-site-form').classList.remove('hidden'); }
function hideSiteForm() { document.getElementById('new-site-form').classList.add('hidden'); }

function countEmps() {
  const n = document.querySelectorAll('input[name="employee_ids[]"]:checked').length;
  document.getElementById('emp-count-label').textContent = n + ' selected';
}

function filterEmployees(q) {
  document.querySelectorAll('.emp-check-row').forEach(row => {
    row.style.display = row.dataset.name.includes(q.toLowerCase()) ? '' : 'none';
  });
}

function selectAllEmps(check) {
  document.querySelectorAll('input[name="employee_ids[]"]').forEach(cb => cb.checked = check);
  countEmps();
}

function buildReview() {
  const svcInput = document.querySelector('input[name="service_id"]:checked');
  document.getElementById('rev-service').textContent = svcInput ? svcInput.dataset.name : '—';
  document.getElementById('rev-date').textContent    = document.querySelector('[name="preferred_date"]').value || '—';
  const t = document.querySelector('[name="preferred_time"]').value;
  document.getElementById('rev-time').textContent = t || 'Any time';

  const siteRadio = document.querySelector('input[name="site_id"]:checked');
  if (siteRadio) {
    if (siteRadio.value === 'new') {
      const addr = document.querySelector('[name="new_site_address"]').value;
      document.getElementById('rev-site').textContent = addr || 'New site (address pending)';
    } else {
      const siteInner = siteRadio.nextElementSibling;
      document.getElementById('rev-site').textContent = siteInner ? siteInner.querySelector('strong').textContent : '—';
    }
  } else {
    const addr = document.querySelector('[name="new_site_address"]').value;
    document.getElementById('rev-site').textContent = addr || '—';
  }

  const checked = [...document.querySelectorAll('input[name="employee_ids[]"]:checked')];
  if (checked.length === 0) {
    document.getElementById('rev-emps').textContent = 'None selected (admin will assign)';
  } else {
    const names = checked.map(cb => {
      const row = cb.closest('.emp-check-row');
      return row.querySelector('strong').textContent;
    });
    document.getElementById('rev-emps').textContent = names.join(', ');
  }
}
</script>

<script src="/js/main.js"></script>
</body>
</html>
