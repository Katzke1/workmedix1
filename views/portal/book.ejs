<%- include('../partials/head') %>
<body>
<div class="app-body">
  <%- include('../partials/portal-sidebar') %>
  <main class="app-main">
    <div class="app-topbar">
      <div class="app-topbar-title">
        <h2>Book a Screening</h2>
        <p>Complete the steps below to request a mobile screening appointment</p>
      </div>
    </div>

    <div class="app-content">
      <div class="book-wrap">
        <% if (locals.error)   { %><div class="alert alert-danger" style="margin-bottom:1.25rem;"><%= error %></div><% } %>
        <% if (locals.success) { %><div class="alert alert-success" style="margin-bottom:1.25rem;"><%= success %></div><% } %>

        <!-- Step progress bar -->
        <div class="bk-stepper" id="booking-steps">
          <div class="bk-step active" data-step="1">
            <div class="bk-step-bubble">
              <span class="bk-step-num">1</span>
              <svg class="bk-step-check" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="2.5 8 6.5 12 13.5 4"/></svg>
            </div>
            <span class="bk-step-label">Service &amp; Date</span>
          </div>
          <div class="bk-step-line"></div>
          <div class="bk-step" data-step="2">
            <div class="bk-step-bubble">
              <span class="bk-step-num">2</span>
              <svg class="bk-step-check" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="2.5 8 6.5 12 13.5 4"/></svg>
            </div>
            <span class="bk-step-label">Location</span>
          </div>
          <div class="bk-step-line"></div>
          <div class="bk-step" data-step="3">
            <div class="bk-step-bubble">
              <span class="bk-step-num">3</span>
              <svg class="bk-step-check" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="2.5 8 6.5 12 13.5 4"/></svg>
            </div>
            <span class="bk-step-label">Employees</span>
          </div>
          <div class="bk-step-line"></div>
          <div class="bk-step" data-step="4">
            <div class="bk-step-bubble">
              <span class="bk-step-num">4</span>
              <svg class="bk-step-check" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="2.5 8 6.5 12 13.5 4"/></svg>
            </div>
            <span class="bk-step-label">Review</span>
          </div>
        </div>

        <form method="POST" action="/portal/book" id="booking-form">
          <%- include('../partials/csrf') %>

          <!-- ── Step 1: Service & Date ─────────────────────────────────────── -->
          <div class="book-panel active" id="step-1">
            <div class="card">
              <div class="card-header">
                <h3>Service &amp; Date</h3>
                <span class="card-header-sub">Choose what you need and when</span>
              </div>
              <div class="card-body">

                <div class="form-group">
                  <label class="form-label">Service Type <span class="req">*</span></label>
                  <div class="svc-grid" id="service-grid">
                    <% services.forEach(svc => { %>
                    <label class="svc-card">
                      <input type="radio" name="service_id" value="<%= svc.id %>" data-name="<%= svc.service_name %>" required>
                      <div class="svc-card-inner">
                        <div class="svc-check-ring">
                          <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="2.5 8 6.5 12 13.5 4"/></svg>
                        </div>
                        <div class="svc-card-text">
                          <strong><%= svc.service_name %></strong>
                          <span>R<%= svc.default_price.toLocaleString() %> / person</span>
                        </div>
                      </div>
                    </label>
                    <% }) %>
                  </div>
                  <p id="svc-error" class="field-error" style="display:none;">Please select a service.</p>
                </div>

                <div class="form-row-2">
                  <div class="form-group">
                    <label class="form-label" for="preferred_date">Preferred Date <span class="req">*</span></label>
                    <input type="date" id="preferred_date" name="preferred_date" class="form-control"
                           min="<%= new Date().toISOString().split('T')[0] %>" required>
                    <span class="form-hint">We confirm the exact time by email.</span>
                    <p id="date-error" class="field-error" style="display:none;">Please pick a date.</p>
                  </div>
                  <div class="form-group">
                    <label class="form-label" for="preferred_time">Preferred Time</label>
                    <select id="preferred_time" name="preferred_time" class="form-control">
                      <option value="">— Any time —</option>
                      <option>07:00</option><option>08:00</option><option>09:00</option>
                      <option>10:00</option><option>11:00</option><option>13:00</option>
                      <option>14:00</option>
                    </select>
                  </div>
                </div>

                <div class="form-group">
                  <label class="form-label" for="notes">Additional Notes</label>
                  <textarea id="notes" name="notes" class="form-control" rows="3" maxlength="500"
                            placeholder="Special requirements, access instructions…"></textarea>
                  <span class="form-hint char-count" id="notes-count">0 / 500</span>
                </div>

                <div class="step-nav">
                  <button type="button" class="btn btn-primary step-next" data-next="2">Next: Location →</button>
                </div>
              </div>
            </div>
          </div>

          <!-- ── Step 2: Location ───────────────────────────────────────────── -->
          <div class="book-panel hidden" id="step-2">
            <div class="card">
              <div class="card-header">
                <h3>Screening Location</h3>
                <span class="card-header-sub">Where should we come to you?</span>
              </div>
              <div class="card-body">
                <div class="form-group">
                  <label class="form-label" for="loc_address">Street Address <span class="req">*</span></label>
                  <input type="text" id="loc_address" name="loc_address" class="form-control"
                         placeholder="e.g. 123 Main Street, Industrial Park" autocomplete="street-address">
                  <p id="loc-error" class="field-error" style="display:none;">Please enter a street address.</p>
                </div>
                <div class="form-row-2">
                  <div class="form-group">
                    <label class="form-label" for="loc_city">City / Town</label>
                    <input type="text" id="loc_city" name="loc_city" class="form-control"
                           placeholder="Johannesburg" autocomplete="address-level2">
                  </div>
                  <div class="form-group">
                    <label class="form-label" for="loc_province">Province</label>
                    <select id="loc_province" name="loc_province" class="form-control">
                      <option value="">— Select —</option>
                      <option>Gauteng</option><option>Western Cape</option><option>KwaZulu-Natal</option>
                      <option>Eastern Cape</option><option>Limpopo</option><option>Mpumalanga</option>
                      <option>North West</option><option>Free State</option><option>Northern Cape</option>
                    </select>
                  </div>
                </div>
                <div class="form-group">
                  <label class="form-label" for="loc_contact">On-site Contact <span style="color:var(--ink-muted);font-weight:400;">(optional)</span></label>
                  <input type="text" id="loc_contact" name="loc_contact" class="form-control"
                         placeholder="Name and phone number of person to meet on the day">
                </div>

                <div class="step-nav">
                  <button type="button" class="btn btn-ghost step-back" data-back="1">← Back</button>
                  <button type="button" class="btn btn-primary step-next" data-next="3">Next: Employees →</button>
                </div>
              </div>
            </div>
          </div>

          <!-- ── Step 3: Number of Employees ──────────────────────────────────── -->
          <div class="book-panel hidden" id="step-3">
            <div class="card">
              <div class="card-header">
                <h3>Number of Employees</h3>
                <span class="card-header-sub">How many people will be screened?</span>
              </div>
              <div class="card-body">
                <div class="emp-count-wrap">
                  <div class="form-group" style="max-width:260px;">
                    <label class="form-label" for="num_employees">Total employees to screen <span class="req">*</span></label>
                    <div class="emp-count-row">
                      <button type="button" class="emp-stepper-btn" id="emp-decrement">−</button>
                      <input type="number" id="num_employees" name="num_employees"
                             class="form-control emp-count-input" min="1" max="500" value="1" required>
                      <button type="button" class="emp-stepper-btn" id="emp-increment">+</button>
                    </div>
                    <span class="form-hint">Our team will bring the necessary equipment for this headcount.</span>
                    <p id="emp-count-error" class="field-error" style="display:none;">Please enter at least 1 employee.</p>
                  </div>
                </div>

                <div class="step-nav" style="margin-top:1.5rem;">
                  <button type="button" class="btn btn-ghost step-back" data-back="2">← Back</button>
                  <button type="button" class="btn btn-primary step-next" data-next="4">Next: Review →</button>
                </div>
              </div>
            </div>
          </div>

          <!-- ── Step 4: Review & Submit ─────────────────────────────────────── -->
          <div class="book-panel hidden" id="step-4">
            <div class="card">
              <div class="card-header">
                <h3>Review &amp; Submit</h3>
                <span class="card-header-sub">Confirm your details before submitting</span>
              </div>
              <div class="card-body">
                <div class="review-grid" id="review-summary">
                  <div class="review-item">
                    <div class="review-icon">
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="16" height="16"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                    </div>
                    <div><span class="review-label">Service</span><strong id="rev-service" class="review-val">—</strong></div>
                  </div>
                  <div class="review-item">
                    <div class="review-icon">
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="16" height="16"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                    </div>
                    <div><span class="review-label">Date &amp; Time</span><strong id="rev-datetime" class="review-val">—</strong></div>
                  </div>
                  <div class="review-item">
                    <div class="review-icon">
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="16" height="16"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
                    </div>
                    <div><span class="review-label">Location</span><strong id="rev-site" class="review-val">—</strong></div>
                  </div>
                  <div class="review-item">
                    <div class="review-icon">
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="16" height="16"><circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 3.58-7 8-7s8 3 8 7"/></svg>
                    </div>
                    <div><span class="review-label">Employees</span><strong id="rev-emps" class="review-val">—</strong></div>
                  </div>

                </div>

                <p class="review-notice">
                  Once submitted, our scheduling team will review your request and confirm within one business day.
                </p>

                <div class="step-nav">
                  <button type="button" class="btn btn-ghost step-back" data-back="3">← Back</button>
                  <button type="submit" class="btn btn-primary">Submit Booking Request →</button>
                </div>
              </div>
            </div>
          </div>

        </form>

        <!-- What happens next card -->
        <div class="card next-card">
          <div class="card-body" style="display:flex;gap:1rem;align-items:flex-start;">
            <div class="next-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" width="18" height="18"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
            </div>
            <div>
              <h4 style="color:var(--primary);margin-bottom:.5rem;font-size:.95rem;">What happens next?</h4>
              <ol class="next-list">
                <li>Your request is logged and assigned to our scheduling team.</li>
                <li>We confirm your appointment date, time, and location via email.</li>
                <li>After your screening, results are uploaded to your portal within 24–48 hours.</li>
                <li>Certificates are issued upon completion and review.</li>
              </ol>
            </div>
          </div>
        </div>
      </div>
    </div>
  </main>
</div>

<style>
/* ── Page layout ───────────────────────── */
.book-wrap { max-width: none; }

/* ── Stepper ───────────────────────────── */
.bk-stepper {
  display: flex;
  align-items: center;
  margin-bottom: 2rem;
  gap: 0;
}
.bk-step {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: .35rem;
  position: relative;
  flex-shrink: 0;
}
.bk-step-bubble {
  width: 36px;
  height: 36px;
  border-radius: 50%;
  background: var(--surface-2);
  border: 2px solid var(--border);
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 700;
  font-size: .82rem;
  color: var(--ink-muted);
  position: relative;
  transition: background .2s, border-color .2s, color .2s;
}
.bk-step-num  { display: block; }
.bk-step-check { display: none; width: 16px; height: 16px; }
.bk-step-label {
  font-size: .78rem;
  font-weight: 500;
  color: var(--ink-muted);
  white-space: nowrap;
  transition: color .2s;
}
.bk-step-line {
  flex: 1;
  height: 2px;
  background: var(--border);
  margin: 0 .25rem;
  margin-bottom: 1.1rem; /* align with bubble center */
  transition: background .2s;
}
/* Active step */
.bk-step.active .bk-step-bubble {
  background: var(--primary);
  border-color: var(--primary);
  color: white;
  box-shadow: 0 0 0 4px rgba(35,38,242,.15);
}
.bk-step.active .bk-step-label { color: var(--primary); font-weight: 600; }
/* Done step */
.bk-step.done .bk-step-bubble {
  background: #e8faf0;
  border-color: #27ae60;
  color: #27ae60;
}
.bk-step.done .bk-step-num  { display: none; }
.bk-step.done .bk-step-check { display: block; stroke: #27ae60; }
.bk-step.done .bk-step-label { color: #27ae60; }
.bk-step.done ~ .bk-step-line { background: #27ae60; }

/* ── Card header extras ──────────────── */
.card-header-sub   { font-size: .82rem; color: var(--ink-muted); font-weight: 400; }
.card-header-badge {
  font-size: .8rem;
  font-weight: 600;
  color: var(--primary);
  background: rgba(35,38,242,.07);
  padding: .25rem .75rem;
  border-radius: 20px;
}

/* ── Service cards ───────────────────── */
.svc-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: .65rem;
  margin-top: .5rem;
}
/* If the last card is alone in its row (odd position in a 2-col grid), center it */
.svc-card:last-child:nth-child(odd) { grid-column: 1 / -1; }
.svc-card:last-child:nth-child(odd) .svc-card-inner { max-width: 50%; }
.svc-card { display: block; cursor: pointer; }
.svc-card input[type="radio"] { position: absolute; opacity: 0; width: 0; height: 0; }
.svc-card-inner {
  display: flex;
  align-items: center;
  gap: .85rem;
  border: 2px solid var(--border);
  border-radius: 10px;
  padding: .85rem 1rem;
  background: var(--surface-2);
  cursor: pointer;
  transition: border-color .15s, background .15s, box-shadow .15s;
}
.svc-card-inner:hover { border-color: rgba(35,38,242,.35); background: #fbfbff; }
.svc-card input:checked + .svc-card-inner {
  border-color: var(--primary);
  background: rgba(35,38,242,.04);
  box-shadow: 0 0 0 3px rgba(35,38,242,.08);
}
.svc-check-ring {
  width: 22px;
  height: 22px;
  border-radius: 50%;
  border: 2px solid var(--border);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  transition: border-color .15s, background .15s;
}
.svc-check-ring svg { width: 12px; height: 12px; stroke: transparent; transition: stroke .15s; }
.svc-card input:checked + .svc-card-inner .svc-check-ring {
  background: var(--primary);
  border-color: var(--primary);
}
.svc-card input:checked + .svc-card-inner .svc-check-ring svg { stroke: white; }
.svc-card-text { display: flex; flex-direction: column; gap: .15rem; }
.svc-card-text strong { font-size: .9rem; color: var(--ink); font-weight: 600; }
.svc-card-text span   { font-size: .8rem; color: var(--ink-muted); }

/* ── Form layout ─────────────────────── */
.form-row-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 1.25rem; }
.form-hint  { font-size: .8rem; color: var(--ink-muted); }
.field-error { font-size: .82rem; color: var(--danger); margin-top: .3rem; }
.req { color: var(--danger); }
.char-count { display: block; margin-top: .25rem; }


/* ── Employee count stepper ──────────── */
.emp-count-wrap { padding: 1.5rem 0; }
.emp-count-row {
  display: flex;
  align-items: center;
  gap: .5rem;
  margin-top: .5rem;
}
.emp-count-input {
  width: 90px !important;
  text-align: center;
  font-size: 1.2rem !important;
  font-weight: 600 !important;
}
.emp-stepper-btn {
  width: 38px;
  height: 38px;
  border-radius: 8px;
  border: 2px solid var(--border);
  background: var(--surface-2);
  color: var(--ink);
  font-size: 1.3rem;
  line-height: 1;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 500;
  transition: border-color .15s, background .15s;
}
.emp-stepper-btn:hover { border-color: var(--primary); background: rgba(35,38,242,.05); color: var(--primary); }

/* ── Review grid ─────────────────────── */
.review-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: .85rem;
  margin-bottom: 1.25rem;
}
.review-item {
  display: flex;
  align-items: flex-start;
  gap: .75rem;
  background: var(--surface-2);
  border: 1px solid var(--border);
  border-radius: 10px;
  padding: .9rem 1rem;
}
.review-icon {
  width: 30px;
  height: 30px;
  border-radius: 7px;
  background: rgba(35,38,242,.08);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.review-icon svg { stroke: var(--primary); }
.review-label { display: block; font-size: .76rem; color: var(--ink-muted); text-transform: uppercase; letter-spacing: .04em; font-weight: 600; margin-bottom: .2rem; }
.review-val   { display: block; font-size: .9rem; color: var(--ink); }
.review-notice { font-size: .88rem; color: var(--ink-muted); margin-bottom: 1.25rem; line-height: 1.6; }

/* ── Step nav buttons ────────────────── */
.step-nav { display: flex; gap: .75rem; margin-top: 1.25rem; }
.btn-ghost {
  background: transparent;
  color: var(--ink);
  border: 2px solid var(--border);
}
.btn-ghost:hover { background: var(--surface-2); border-color: var(--ink-muted); }

/* ── What's next card ────────────────── */
.next-card { margin-top: 1.25rem; border-left: 3px solid var(--accent); }
.next-icon {
  flex-shrink: 0;
  width: 38px;
  height: 38px;
  border-radius: 10px;
  background: linear-gradient(135deg, var(--primary), var(--accent));
  display: flex;
  align-items: center;
  justify-content: center;
}
.next-list { padding-left: 1.2rem; color: var(--text-light, var(--ink-muted)); font-size: .88rem; line-height: 1.9; margin: 0; }

/* ── Hidden panels ───────────────────── */
.book-panel.hidden { display: none; }

/* ── Responsive ──────────────────────── */
@media (max-width: 600px) {
  .svc-grid   { grid-template-columns: 1fr; }
  .form-row-2 { grid-template-columns: 1fr; }
  .review-grid { grid-template-columns: 1fr; }
  .bk-step-label { display: none; }
  .emp-toolbar { flex-direction: column; align-items: stretch; }
  .emp-search-input { width: 100%; }
}
</style>

<script>
(function () {

  /* ── Step navigation ───────────────────────────────────────── */
  function goStep(n) {
    document.querySelectorAll('.book-panel').forEach(function (p, i) {
      p.classList.toggle('hidden', i + 1 !== n);
    });
    document.querySelectorAll('.bk-step').forEach(function (s) {
      var num = parseInt(s.dataset.step, 10);
      s.classList.remove('active', 'done');
      if (num === n) s.classList.add('active');
      if (num < n)  s.classList.add('done');
    });
    // Update line colours — lines sit between steps at DOM level
    document.querySelectorAll('.bk-step-line').forEach(function (line, i) {
      // line index i sits after step i+1; colour it if step i+1 is done
      line.style.background = (i + 1 < n) ? '#27ae60' : '';
    });
    window.scrollTo({ top: 0, behavior: 'smooth' });
    if (n === 4) buildReview();
  }

  /* ── Validation helpers ────────────────────────────────────── */
  function validateStep1() {
    var ok = true;
    var svcEl = document.getElementById('svc-error');
    var dateEl = document.getElementById('date-error');
    var svcChecked = document.querySelector('input[name="service_id"]:checked');
    var dateVal    = document.getElementById('preferred_date').value;
    svcEl.style.display  = svcChecked  ? 'none' : 'block';
    dateEl.style.display = dateVal     ? 'none' : 'block';
    if (!svcChecked || !dateVal) ok = false;
    return ok;
  }

  function validateStep2() {
    var addr  = document.getElementById('loc_address');
    var errEl = document.getElementById('loc-error');
    if (!addr || !addr.value.trim()) {
      if (errEl) errEl.style.display = 'block';
      return false;
    }
    if (errEl) errEl.style.display = 'none';
    return true;
  }

  /* ── Step 3 validation ─────────────────────────────────────── */
  function validateStep3() {
    var inp = document.getElementById('num_employees');
    var err = document.getElementById('emp-count-error');
    var v   = parseInt(inp ? inp.value : '0', 10);
    if (!inp || v < 1) { if (err) err.style.display = 'block'; return false; }
    if (err) err.style.display = 'none';
    return true;
  }

  /* ── Wire up Next / Back buttons ───────────────────────────── */
  document.querySelectorAll('.step-next').forEach(function (btn) {
    btn.addEventListener('click', function () {
      var next = parseInt(btn.dataset.next, 10);
      var from = next - 1;
      // Validate the step we're leaving
      if (from === 1 && !validateStep1()) return;
      if (from === 2 && !validateStep2()) return;
      if (from === 3 && !validateStep3()) return;
      goStep(next);
    });
  });

  document.querySelectorAll('.step-back').forEach(function (btn) {
    btn.addEventListener('click', function () {
      goStep(parseInt(btn.dataset.back, 10));
    });
  });


  /* ── Employee count stepper ─────────────────────────────────── */
  var empInput = document.getElementById('num_employees');
  var empDec   = document.getElementById('emp-decrement');
  var empInc   = document.getElementById('emp-increment');
  if (empDec && empInc && empInput) {
    empDec.addEventListener('click', function () {
      var v = parseInt(empInput.value, 10) || 1;
      if (v > 1) empInput.value = v - 1;
    });
    empInc.addEventListener('click', function () {
      var v = parseInt(empInput.value, 10) || 1;
      if (v < 500) empInput.value = v + 1;
    });
  }

  /* ── Notes character counter ────────────────────────────────── */
  var notes = document.getElementById('notes');
  var notesCount = document.getElementById('notes-count');
  if (notes && notesCount) {
    notes.addEventListener('input', function () {
      var len = this.value.length;
      notesCount.textContent = len + ' / 500';
      notesCount.style.color = len > 450 ? '#ef4444' : '';
    });
  }

  /* ── Build review summary ───────────────────────────────────── */
  function buildReview() {
    var svcInput = document.querySelector('input[name="service_id"]:checked');
    document.getElementById('rev-service').textContent = svcInput ? svcInput.dataset.name : '—';

    var date = document.getElementById('preferred_date').value || '—';
    var time = document.getElementById('preferred_time').value || 'Any time';
    document.getElementById('rev-datetime').textContent = date + ' · ' + time;

    var addrEl = document.getElementById('loc_address');
    var cityEl = document.getElementById('loc_city');
    var provEl = document.getElementById('loc_province');
    var parts  = [];
    if (addrEl && addrEl.value.trim()) parts.push(addrEl.value.trim());
    if (cityEl && cityEl.value.trim()) parts.push(cityEl.value.trim());
    if (provEl && provEl.value)        parts.push(provEl.value);
    document.getElementById('rev-site').textContent = parts.length ? parts.join(', ') : '—';

    var empCount = parseInt((document.getElementById('num_employees') || {}).value, 10) || 1;
    document.getElementById('rev-emps').textContent = empCount + (empCount === 1 ? ' employee' : ' employees');
  }

})();
</script>

<script src="/js/main.js"></script>
</body>
</html>
