<%- include('../partials/head') %>
<body>
<div class="app-body">
<%- include('../partials/portal-sidebar') %>
<main class="app-main">
  <div class="app-topbar">
    <div class="app-topbar-title">
      <h2>My Certificates</h2>
      <p>Issued occupational health certificates</p>
    </div>
  </div>

  <div class="app-content">
    <div class="card">
      <div class="card-header">
        <h3>Issued Certificates</h3>
        <span style="font-size:.85rem;color:var(--mid-grey);"><%= certificates.length %> certificate<%= certificates.length !== 1 ? 's' : '' %></span>
      </div>
      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th>Certificate</th>
              <th>Issue Date</th>
              <th>Action</th>
            </tr>
          </thead>
          <tbody>
            <% if (certificates.length === 0) { %>
              <tr>
                <td class="table-empty" colspan="3">
                  No certificates issued yet.<br>
                  <span style="font-size:.85rem;">Certificates are issued after your screening is reviewed and approved by our practitioners.</span>
                </td>
              </tr>
            <% } else { certificates.forEach(c => { %>
              <tr>
                <td>
                  <div style="display:flex;align-items:center;gap:.7rem;">
                    <div style="width:38px;height:38px;background:linear-gradient(135deg,#0b6e4f,#00b894);border-radius:10px;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                      <svg viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="18" height="18"><circle cx="12" cy="8" r="6"/><path d="M15.477 12.89L17 22l-5-3-5 3 1.523-9.11"/></svg>
                    </div>
                    <div>
                      <strong><%= c.title %></strong>
                    </div>
                  </div>
                </td>
                <td style="color:var(--mid-grey);font-size:.85rem;white-space:nowrap;">
                  <%= new Date(c.issued_at).toLocaleDateString('en-ZA', {day:'numeric',month:'long',year:'numeric'}) %>
                </td>
                <td>
                  <a href="/portal/certificates/<%= c.id %>/download"
                     class="btn btn-primary btn-sm">
                    ↓ Download
                  </a>
                </td>
              </tr>
            <% }) } %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</main>
</div>
<script src="/js/main.js"></script>
</body>
</html>
