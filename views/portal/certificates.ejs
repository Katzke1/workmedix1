<%- include('../partials/head') %>
<body>
<div class="app-body">
<%- include('../partials/portal-sidebar') %>
<main class="app-main">
  <div class="app-topbar">
    <div class="app-topbar-title">
      <h2>My Certificates</h2>
      <p>Issued occupational health certificates</p>
    </div>
  </div>

  <div class="app-content">
    <% const expiring = certificates.filter(c => c.expiry_date && new Date(c.expiry_date) <= new Date(Date.now() + 60*24*60*60*1000)); %>
    <% if (expiring.length > 0) { %>
    <div class="alert alert-warning" style="background:#FFF8E1;border:1px solid #F59E0B;border-left:4px solid #F59E0B;border-radius:8px;padding:1rem 1.25rem;margin-bottom:1.25rem;display:flex;align-items:center;gap:.75rem;">
      <svg viewBox="0 0 24 24" fill="none" stroke="#F59E0B" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="20" height="20"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
      <span><strong><%= expiring.length %> certificate<%= expiring.length!==1?'s':'' %></strong> expiring within 60 days. Contact us to arrange renewal.</span>
    </div>
    <% } %>

    <div class="card">
      <div class="card-header" style="flex-wrap:wrap;gap:.75rem;align-items:center;">
        <h3 style="margin-right:auto;">Issued Certificates</h3>
        <input type="text" id="cert-search" class="form-control" placeholder="Search name, title, cert #…"
               style="max-width:230px;padding:.5rem .7rem;font-size:.85rem;" autocomplete="off">
        <select id="cert-sort" class="form-control" style="max-width:190px;padding:.5rem .7rem;font-size:.85rem;">
          <option value="issued-desc">Issued (newest)</option>
          <option value="issued-asc">Issued (oldest)</option>
          <option value="expiry-asc">Expiry (soonest)</option>
          <option value="name-asc">Name (A–Z)</option>
        </select>
      </div>
      <div class="table-wrap">
        <% if (certificates.length === 0) { %>
          <%- include('../partials/empty-state', { title: 'No certificates yet', desc: 'Certificates are issued after your screening is reviewed and approved by our practitioners.', ctaHref: '/portal/book' }) %>
        <% } else { %>
        <table>
          <thead>
            <tr>
              <th>Certificate</th>
              <th>Cert #</th>
              <th>Issued</th>
              <th>Expires</th>
              <th>Status</th>
              <th></th>
            </tr>
          </thead>
          <tbody id="cert-body">
            <% certificates.forEach(c => { %>
            <% const now = Date.now(); %>
            <% const isExpired  = c.expiry_date && new Date(c.expiry_date) < now; %>
            <% const isExpiring = c.expiry_date && !isExpired && new Date(c.expiry_date) <= new Date(now + 60*24*60*60*1000); %>
            <% const ownerName = (c.first_name || c.last_name) ? `${c.first_name||''} ${c.last_name||''}`.trim() : ''; %>
            <% const issuedISO = c.issued_date || (c.issued_at || '').slice(0,10); %>
            <tr class="cert-row"
                data-name="<%= ownerName.toLowerCase() %>"
                data-text="<%= (c.title + ' ' + (c.certificate_number||'') + ' ' + ownerName).toLowerCase() %>"
                data-issued="<%= issuedISO %>"
                data-expiry="<%= c.expiry_date || '' %>">
              <td>
                <div style="display:flex;align-items:center;gap:.7rem;">
                  <div style="width:38px;height:38px;background:linear-gradient(135deg,#0b6e4f,#00b894);border-radius:10px;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                    <svg viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="18" height="18"><circle cx="12" cy="8" r="6"/><path d="M15.477 12.89L17 22l-5-3-5 3 1.523-9.11"/></svg>
                  </div>
                  <div>
                    <strong><%= c.title %></strong>
                    <% if (ownerName) { %><div style="font-size:.78rem;color:var(--mid-grey);"><%= ownerName %><%= c.id_number ? ' · ' + c.id_number : '' %></div><% } %>
                  </div>
                </div>
              </td>
              <td style="font-size:.82rem;color:var(--ink-muted);font-family:monospace;"><%= c.certificate_number || '—' %></td>
              <td style="color:var(--mid-grey);font-size:.85rem;white-space:nowrap;">
                <%= c.issued_date ? new Date(c.issued_date).toLocaleDateString('en-ZA',{day:'numeric',month:'short',year:'numeric'}) : new Date(c.issued_at).toLocaleDateString('en-ZA',{day:'numeric',month:'short',year:'numeric'}) %>
              </td>
              <td style="font-size:.85rem;white-space:nowrap;">
                <% if (c.expiry_date) { %>
                  <span style="color:<%= isExpired ? 'var(--danger)' : isExpiring ? '#F59E0B' : 'var(--ink-muted)' %>;">
                    <%= new Date(c.expiry_date).toLocaleDateString('en-ZA',{day:'numeric',month:'short',year:'numeric'}) %>
                  </span>
                <% } else { %>—<% } %>
              </td>
              <td>
                <% if (isExpired) { %>
                  <span class="badge badge-cancelled">Expired</span>
                <% } else if (isExpiring) { %>
                  <span class="badge badge-pending">Expiring soon</span>
                <% } else { %>
                  <span class="badge badge-confirmed">Valid</span>
                <% } %>
              </td>
              <td>
                <% if (c.file_path) { %>
                <a href="/portal/certificates/<%= c.id %>/download" class="btn btn-outline-dark btn-sm">↓ Download</a>
                <% } else { %>
                <span style="font-size:.8rem;color:var(--ink-muted);">No file</span>
                <% } %>
              </td>
            </tr>
            <% }) %>
          </tbody>
        </table>
        <% } %>
      </div>
    </div>
  </div>
</main>
</div>
<script>
(function () {
  const body = document.getElementById('cert-body');
  if (!body) return;
  const search = document.getElementById('cert-search');
  const sort   = document.getElementById('cert-sort');
  const rows   = Array.from(body.querySelectorAll('.cert-row'));

  function apply() {
    const term = (search.value || '').trim().toLowerCase();
    rows.forEach(r => { r.style.display = (!term || r.dataset.text.includes(term)) ? '' : 'none'; });

    const [key, dir] = sort.value.split('-');
    const mult = dir === 'asc' ? 1 : -1;
    rows.slice().sort((a, b) => {
      const av = key === 'name' ? a.dataset.name : (a.dataset[key] || '');
      const bv = key === 'name' ? b.dataset.name : (b.dataset[key] || '');
      // empty dates sort last
      if (key === 'expiry') { if (!av) return 1; if (!bv) return -1; }
      return av < bv ? -1 * mult : av > bv ? 1 * mult : 0;
    }).forEach(r => body.appendChild(r));
  }
  search.addEventListener('input', apply);
  sort.addEventListener('change', apply);
  apply();
})();
</script>
<script src="/js/main.js"></script>
</body>
</html>
