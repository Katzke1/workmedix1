<%- include('../partials/head') %>
<body>
<div class="app-body">
<%- include('../partials/admin-sidebar') %>
<main class="app-main">
  <div class="app-topbar">
    <div class="app-topbar-title">
      <h2><%= clientUser.name %></h2>
      <p>Client record<% if (clientUser.company_name) { %> · <%= clientUser.company_name %><% } %></p>
    </div>
    <div class="topbar-actions">
      <a href="/admin/clients" style="font-size:.85rem;color:var(--mid-grey);">← Back to clients</a>
    </div>
  </div>

  <div class="app-content">
    <!-- Client info -->
    <div class="card" style="margin-bottom:1.5rem;">
      <div class="card-body" style="display:flex;gap:1.5rem;flex-wrap:wrap;align-items:center;">
        <div style="width:60px;height:60px;background:var(--primary);border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:1.5rem;font-weight:800;color:white;flex-shrink:0;">
          <%= clientUser.name.charAt(0).toUpperCase() %>
        </div>
        <div style="flex:1;">
          <h3 style="color:var(--primary);margin-bottom:.2rem;"><%= clientUser.name %></h3>
          <div style="display:flex;gap:1.5rem;flex-wrap:wrap;font-size:.88rem;color:var(--text-light);">
            <span><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="13" height="13" style="vertical-align:middle;margin-right:3px;"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg><%= clientUser.email %></span>
            <% if (clientUser.company_name) { %><span><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="13" height="13" style="vertical-align:middle;margin-right:3px;"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 7V5a2 2 0 00-2-2h-4a2 2 0 00-2 2v2"/></svg><%= clientUser.company_name %></span><% } %>
            <span><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="13" height="13" style="vertical-align:middle;margin-right:3px;"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>Registered <%= new Date(clientUser.created_at).toLocaleDateString('en-ZA',{day:'numeric',month:'long',year:'numeric'}) %></span>
          </div>
        </div>
        <div style="display:flex;gap:.75rem;">
          <a href="/admin/results?client=<%= clientUser.id %>" class="btn btn-primary btn-sm">Upload Result</a>
          <a href="/admin/certificates?client=<%= clientUser.id %>" class="btn btn-outline-dark btn-sm">Issue Certificate</a>
        </div>
      </div>
    </div>

    <!-- Bookings -->
    <div class="card" style="margin-bottom:1.5rem;">
      <div class="card-header">
        <h3>Bookings (<%= bookings.length %>)</h3>
      </div>
      <div class="table-wrap">
        <table>
          <thead>
            <tr><th>Service</th><th>Preferred Date</th><th>Status</th><th>Notes</th><th>Submitted</th></tr>
          </thead>
          <tbody>
            <% if (bookings.length === 0) { %>
              <tr><td class="table-empty" colspan="5">No bookings for this client.</td></tr>
            <% } else { bookings.forEach(b => { %>
              <tr>
                <td><strong><%= b.service_type %></strong></td>
                <td><%= b.preferred_date %></td>
                <td><span class="badge badge-<%= b.status %>"><%= b.status.replace(/_/g,' ') %></span></td>
                <td style="color:var(--text-light);font-size:.85rem;max-width:180px;"><%= b.notes ? b.notes.substring(0,60)+'…' : '—' %></td>
                <td style="color:var(--mid-grey);font-size:.82rem;"><%= new Date(b.created_at).toLocaleDateString('en-ZA') %></td>
              </tr>
            <% }) } %>
          </tbody>
        </table>
      </div>
    </div>

    <div class="dash-2col-grid">
      <!-- Results -->
      <div class="card">
        <div class="card-header">
          <h3>Results (<%= results.length %>)</h3>
          <a href="/admin/results" style="font-size:.82rem;color:var(--accent);">+ Upload</a>
        </div>
        <div class="table-wrap">
          <table>
            <thead>
              <tr><th>Title</th><th>Uploaded</th></tr>
            </thead>
            <tbody>
              <% if (results.length === 0) { %>
                <tr><td class="table-empty" colspan="2">No results uploaded.</td></tr>
              <% } else { results.forEach(r => { %>
                <tr>
                  <td style="font-size:.88rem;"><strong><%= r.title %></strong></td>
                  <td style="color:var(--mid-grey);font-size:.82rem;white-space:nowrap;"><%= new Date(r.uploaded_at).toLocaleDateString('en-ZA') %></td>
                </tr>
              <% }) } %>
            </tbody>
          </table>
        </div>
      </div>

      <!-- Certificates -->
      <div class="card">
        <div class="card-header">
          <h3>Certificates (<%= certificates.length %>)</h3>
          <a href="/admin/certificates" style="font-size:.82rem;color:var(--accent);">+ Issue</a>
        </div>
        <div class="table-wrap">
          <table>
            <thead>
              <tr><th>Title</th><th>Issued</th></tr>
            </thead>
            <tbody>
              <% if (certificates.length === 0) { %>
                <tr><td class="table-empty" colspan="2">No certificates issued.</td></tr>
              <% } else { certificates.forEach(c => { %>
                <tr>
                  <td style="font-size:.88rem;"><strong><%= c.title %></strong></td>
                  <td style="color:var(--mid-grey);font-size:.82rem;white-space:nowrap;"><%= new Date(c.issued_at).toLocaleDateString('en-ZA') %></td>
                </tr>
              <% }) } %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
</main>
</div>
<script src="/js/main.js"></script>
</body>
</html>
