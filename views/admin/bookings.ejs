<%- include('../partials/head') %>
<body>
<div class="app-body">
<%- include('../partials/admin-sidebar') %>
<main class="app-main">
  <div class="app-topbar">
    <div class="app-topbar-title">
      <h2>Manage Bookings</h2>
      <p>Review and update client appointment statuses</p>
    </div>
  </div>

  <div class="app-content">
    <% if (success) { %>
      <div class="alert alert-success" data-autodismiss><%= success %></div>
    <% } %>

    <div class="card">
      <div class="card-header">
        <h3>All Bookings</h3>
        <span style="font-size:.85rem;color:var(--mid-grey);"><%= bookings.length %> total</span>
      </div>
      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th>Client</th>
              <th>Company</th>
              <th>Service</th>
              <th>Preferred Date</th>
              <th>Submitted</th>
              <th>Status</th>
              <th>Update</th>
            </tr>
          </thead>
          <tbody>
            <% if (bookings.length === 0) { %>
              <tr><td class="table-empty" colspan="7">No bookings yet.</td></tr>
            <% } else { bookings.forEach(b => { %>
              <tr>
                <td>
                  <strong><%= b.client_name %></strong>
                </td>
                <td style="color:var(--text-light);font-size:.88rem;"><%= b.company_name || '—' %></td>
                <td style="font-size:.9rem;"><%= b.service_type %></td>
                <td style="font-size:.88rem;font-weight:600;"><%= b.preferred_date %></td>
                <td style="color:var(--mid-grey);font-size:.82rem;white-space:nowrap;">
                  <%= new Date(b.created_at).toLocaleDateString('en-ZA') %>
                </td>
                <td><span class="badge badge-<%= b.status %>"><%= b.status %></span></td>
                <td>
                  <form method="POST" action="/admin/bookings/<%= b.id %>/status" class="status-form">
                    <select name="status" title="Update status">
                      <option value="pending"   <%= b.status==='pending'   ? 'selected' : '' %>>Pending</option>
                      <option value="confirmed" <%= b.status==='confirmed' ? 'selected' : '' %>>Confirmed</option>
                      <option value="completed" <%= b.status==='completed' ? 'selected' : '' %>>Completed</option>
                    </select>
                  </form>
                </td>
              </tr>
            <% }) } %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</main>
</div>
<script src="/js/main.js"></script>
</body>
</html>
