<%- include('../partials/head') %>
<body>
<div class="app-body">
<%- include('../partials/admin-sidebar') %>
<main class="app-main">
  <div class="app-topbar">
    <div class="app-topbar-title">
      <h2>Admin Dashboard</h2>
      <p>Workmedix management overview</p>
    </div>
    <div class="topbar-actions">
      <span style="font-size:.85rem;color:var(--mid-grey);">
        <%= new Date().toLocaleDateString('en-ZA',{weekday:'long',day:'numeric',month:'long',year:'numeric'}) %>
      </span>
    </div>
  </div>

  <div class="app-content">
    <!-- Welcome banner -->
    <div class="dash-welcome-banner">
      <div class="dash-welcome-logo">
        <img src="/images/logo-white.png" alt="Workmedix">
      </div>
      <div class="dash-welcome-text">
        <h3>Welcome back, <%= user.name.split(' ')[0] %></h3>
        <p>Workmedix Admin Panel &nbsp;·&nbsp; <%= new Date().toLocaleDateString('en-ZA',{weekday:'long',day:'numeric',month:'long',year:'numeric'}) %></p>
      </div>
    </div>

    <!-- Stats -->
    <div class="stats-grid">
      <div class="stat-card">
        <div class="stat-icon blue">
          <svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87"/><path d="M16 3.13a4 4 0 010 7.75"/></svg>
        </div>
        <div>
          <div class="stat-num"><%= stats.totalClients %></div>
          <div class="stat-label">Registered Clients</div>
        </div>
      </div>
      <div class="stat-card">
        <div class="stat-icon amber">
          <svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
        </div>
        <div>
          <div class="stat-num"><%= stats.pendingBookings %></div>
          <div class="stat-label">Pending Bookings</div>
        </div>
      </div>
      <div class="stat-card">
        <div class="stat-icon green">
          <svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2h11"/></svg>
        </div>
        <div>
          <div class="stat-num"><%= stats.completedScreenings %></div>
          <div class="stat-label">Completed Screenings</div>
        </div>
      </div>
      <div class="stat-card">
        <div class="stat-icon purple">
          <svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="6"/><path d="M15.477 12.89L17 22l-5-3-5 3 1.523-9.11"/></svg>
        </div>
        <div>
          <div class="stat-num"><%= stats.certificatesIssued %></div>
          <div class="stat-label">Certificates Issued</div>
        </div>
      </div>
    </div>

    <!-- Recent bookings -->
    <div class="card">
      <div class="card-header">
        <h3>Recent Bookings</h3>
        <a href="/admin/bookings" style="font-size:.85rem;color:var(--accent);">View all →</a>
      </div>
      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th>Client</th>
              <th>Company</th>
              <th>Service</th>
              <th>Date Requested</th>
              <th>Status</th>
            </tr>
          </thead>
          <tbody>
            <% if (recentBookings.length === 0) { %>
              <tr><td class="table-empty" colspan="5">No bookings yet.</td></tr>
            <% } else { recentBookings.forEach(b => { %>
              <tr>
                <td><strong><%= b.client_name %></strong></td>
                <td style="color:var(--text-light);font-size:.88rem;"><%= b.company_name || '—' %></td>
                <td><%= b.service_type %></td>
                <td style="color:var(--mid-grey);font-size:.88rem;"><%= b.preferred_date %></td>
                <td><span class="badge badge-<%= b.status %>"><%= b.status %></span></td>
              </tr>
            <% }) } %>
          </tbody>
        </table>
      </div>
    </div>

    <!-- Quick actions -->
    <div class="grid-3" style="margin-top:1.5rem;">
      <a href="/admin/bookings" class="quick-action-card">
        <div class="quick-action-icon" style="background:linear-gradient(135deg,#0c2461,#2e86de);">
          <svg viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="26" height="26"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
        </div>
        <h4>Manage Bookings</h4>
        <p>Review and update booking statuses</p>
      </a>
      <a href="/admin/results" class="quick-action-card">
        <div class="quick-action-icon" style="background:linear-gradient(135deg,#e17055,#fd79a8);">
          <svg viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="26" height="26"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
        </div>
        <h4>Upload Results</h4>
        <p>Add screening documents for clients</p>
      </a>
      <a href="/admin/certificates" class="quick-action-card">
        <div class="quick-action-icon" style="background:linear-gradient(135deg,#0b6e4f,#00b894);">
          <svg viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="26" height="26"><circle cx="12" cy="8" r="6"/><path d="M15.477 12.89L17 22l-5-3-5 3 1.523-9.11"/></svg>
        </div>
        <h4>Issue Certificates</h4>
        <p>Generate and upload health certificates</p>
      </a>
    </div>
  </div>
</main>
</div>
<script src="/js/main.js"></script>
</body>
</html>
