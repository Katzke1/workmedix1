<%- include('../partials/head') %>
<body>
<div class="app-body">
<%- include('../partials/admin-sidebar') %>
<main class="app-main">
  <div class="app-topbar">
    <div class="app-topbar-title">
      <h2>Admin Dashboard</h2>
      <p>Workmedix management overview</p>
    </div>
    <div class="topbar-actions">
      <span class="topbar-date" style="font-size:.85rem;color:var(--mid-grey);">
        <%= new Date().toLocaleDateString('en-ZA',{weekday:'long',day:'numeric',month:'long',year:'numeric'}) %>
      </span>
    </div>
  </div>

  <div class="app-content">
    <!-- Welcome banner -->
    <div class="dash-welcome-banner">
      <div class="dash-welcome-logo">
        <img src="/images/logo-white.png" alt="Workmedix">
      </div>
      <div class="dash-welcome-text">
        <h3>Welcome back, <%= user.name.split(' ')[0] %></h3>
        <p>Workmedix Admin Panel &nbsp;·&nbsp; <%= new Date().toLocaleDateString('en-ZA',{weekday:'long',day:'numeric',month:'long',year:'numeric'}) %></p>
      </div>
    </div>

    <!-- OccuPlus integration status -->
    <%
      const _ss      = locals.syncStatus || {};
      const lastSeen = _ss.agent_last_seen ? new Date(_ss.agent_last_seen) : null;
      const minsAgo  = lastSeen ? Math.floor((Date.now() - lastSeen.getTime()) / 60000) : null;
      const healthy  = minsAgo != null && minsAgo < 30;
      const rel = m => m == null ? 'never'
        : m < 1 ? 'just now' : m < 60 ? m + ' min ago'
        : m < 1440 ? Math.floor(m / 60) + 'h ago' : Math.floor(m / 1440) + 'd ago';
      const imported = parseInt(_ss.reports_imported_total || '0', 10);
      const lastImp  = _ss.last_import_at ? new Date(_ss.last_import_at) : null;
    %>
    <div class="sync-status-bar">
      <span class="sync-dot <%= healthy ? 'on' : 'off' %>"></span>
      <div class="sync-status-text">
        <strong>OccuPlus sync agent</strong>
        <span>
          <% if (lastSeen) { %>Last checked in <%= rel(minsAgo) %><% if (!healthy) { %> — may be offline<% } %>
          <% } else { %>Has not connected yet — start the helper app on the screening laptop<% } %>
        </span>
      </div>
      <div class="sync-status-meta">
        <div><span class="num"><%= imported %></span> report<%= imported !== 1 ? 's' : '' %> imported</div>
        <% if (lastImp) { %><div style="font-size:.76rem;color:var(--mid-grey);">last <%= lastImp.toLocaleString('en-ZA',{day:'numeric',month:'short',hour:'2-digit',minute:'2-digit'}) %></div><% } %>
      </div>
    </div>
    <style>
      .sync-status-bar{display:flex;align-items:center;gap:.85rem;background:var(--surface);border:1px solid var(--border);border-radius:var(--radius-lg);padding:.85rem 1.15rem;margin-bottom:1.25rem;box-shadow:0 1px 2px rgba(15,18,60,.04);}
      .sync-dot{width:11px;height:11px;border-radius:50%;flex-shrink:0;}
      .sync-dot.on{background:#10b981;box-shadow:0 0 0 4px rgba(16,185,129,.15);animation:syncpulse 2s ease-in-out infinite;}
      .sync-dot.off{background:#cbd2e0;}
      @keyframes syncpulse{50%{opacity:.4;}}
      .sync-status-text{flex:1;min-width:0;}
      .sync-status-text strong{display:block;font-size:.9rem;}
      .sync-status-text span{display:block;font-size:.8rem;color:var(--mid-grey);}
      .sync-status-meta{text-align:right;white-space:nowrap;}
      .sync-status-meta .num{font-size:1.1rem;font-weight:800;color:var(--primary);}
    </style>

    <!-- Stats row -->
    <div class="stats-grid stats-grid-5">
      <div class="stat-card">
        <div class="stat-icon blue">
          <svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87"/><path d="M16 3.13a4 4 0 010 7.75"/></svg>
        </div>
        <div>
          <div class="stat-num"><%= stats.totalClients %></div>
          <div class="stat-label">Registered Clients</div>
        </div>
      </div>
      <div class="stat-card">
        <div class="stat-icon amber">
          <svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
        </div>
        <div>
          <div class="stat-num"><%= stats.pendingBookings %></div>
          <div class="stat-label">Pending Bookings</div>
        </div>
      </div>
      <div class="stat-card">
        <div class="stat-icon green">
          <svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2h11"/></svg>
        </div>
        <div>
          <div class="stat-num"><%= stats.completedScreenings %></div>
          <div class="stat-label">Completed</div>
        </div>
      </div>
      <div class="stat-card">
        <div class="stat-icon purple">
          <svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="6"/><path d="M15.477 12.89L17 22l-5-3-5 3 1.523-9.11"/></svg>
        </div>
        <div>
          <div class="stat-num"><%= stats.certificatesIssued %></div>
          <div class="stat-label">Certificates</div>
        </div>
      </div>
      <div class="stat-card stat-card-danger">
        <div class="stat-icon red">
          <svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
        </div>
        <div>
          <div class="stat-num stat-num-danger"><%= stats.expiringCerts %></div>
          <div class="stat-label">Expiring (&le;60d)</div>
        </div>
      </div>
    </div>

    <!-- 4-quadrant grid -->
    <div class="dash-2col-grid">

      <!-- Upcoming bookings (next 7 days) -->
      <div class="card">
        <div class="card-header">
          <h3>Upcoming Bookings</h3>
          <a href="/admin/bookings?status=confirmed" style="font-size:.82rem;color:var(--primary);">View all →</a>
        </div>
        <% if (upcomingBookings.length === 0) { %>
          <div class="card-body" style="color:var(--ink-muted);font-size:.9rem;">No confirmed bookings in the next 7 days.</div>
        <% } else { %>
        <div style="display:flex;flex-direction:column;">
          <% upcomingBookings.forEach(b => { %>
          <a href="/admin/bookings/<%= b.id %>" style="display:flex;align-items:center;justify-content:space-between;padding:.7rem 1rem;border-bottom:1px solid var(--border);text-decoration:none;color:inherit;transition:background .12s;" onmouseover="this.style.background='var(--surface-2)'" onmouseout="this.style.background=''">
            <div>
              <strong style="font-size:.9rem;"><%= b.service_type %></strong>
              <div style="font-size:.8rem;color:var(--ink-muted);"><%= b.company_name || b.client_name %></div>
            </div>
            <div style="text-align:right;">
              <div style="font-size:.82rem;font-weight:600;"><%= b.preferred_date %></div>
              <span class="badge badge-<%= b.status %>"><%= b.status.replace(/_/g,' ') %></span>
            </div>
          </a>
          <% }) %>
        </div>
        <% } %>
      </div>

      <!-- Expiring certificates -->
      <div class="card">
        <div class="card-header">
          <h3>Expiring Certificates</h3>
          <a href="/admin/certificates" style="font-size:.82rem;color:var(--primary);">Issue cert →</a>
        </div>
        <% if (expiringCerts.length === 0) { %>
          <div class="card-body" style="color:var(--ink-muted);font-size:.9rem;">No certificates expiring in the next 60 days.</div>
        <% } else { %>
        <div style="display:flex;flex-direction:column;">
          <% expiringCerts.forEach(c => { %>
          <div style="display:flex;align-items:center;justify-content:space-between;padding:.7rem 1rem;border-bottom:1px solid var(--border);">
            <div>
              <strong style="font-size:.9rem;"><%= c.first_name || c.user_name %> <%= c.last_name || '' %></strong>
              <div style="font-size:.8rem;color:var(--ink-muted);"><%= c.cert_type_name || c.title %></div>
            </div>
            <% const daysLeft = Math.ceil((new Date(c.expiry_date) - Date.now()) / 86400000); %>
            <span class="badge badge-<%= daysLeft <= 14 ? 'cancelled' : 'pending' %>"><%= daysLeft %>d left</span>
          </div>
          <% }) %>
        </div>
        <% } %>
      </div>

      <!-- CRM / Pipeline summary -->
      <div class="card">
        <div class="card-header">
          <h3>Pipeline Summary</h3>
          <a href="/admin/crm" style="font-size:.82rem;color:var(--primary);">Open CRM →</a>
        </div>
        <div class="card-body" style="display:grid;grid-template-columns:repeat(3,1fr);gap:1rem;text-align:center;">
          <% Object.entries(pipelineSummary).forEach(([status, count]) => { %>
          <div>
            <div class="pipeline-num"><%= count %></div>
            <div style="font-size:.78rem;color:var(--ink-muted);text-transform:capitalize;margin-top:.2rem;"><%= status.replace(/_/g,' ') %></div>
          </div>
          <% }) %>
        </div>
      </div>

      <!-- Revenue this month -->
      <div class="card">
        <div class="card-header">
          <h3>Revenue This Month</h3>
          <a href="/admin/crm/finance" style="font-size:.82rem;color:var(--primary);">Finance →</a>
        </div>
        <div class="card-body">
          <div class="revenue-num">
            R<%= revenueMonth.toLocaleString('en-ZA', {minimumFractionDigits:0}) %>
          </div>
          <div style="font-size:.82rem;color:var(--ink-muted);margin-top:.25rem;">
            from <%= jobsMonth %> completed job<%= jobsMonth===1?'':'s' %> · invoiced or paid
          </div>
          <% if (revenuePrev > 0) { %>
          <div style="font-size:.82rem;margin-top:.5rem;">
            <% const delta = revenueMonth - revenuePrev; %>
            <span style="color:<%= delta>=0 ? '#10B981' : 'var(--danger)' %>;">
              <%= delta >= 0 ? '▲' : '▼' %> R<%= Math.abs(delta).toLocaleString('en-ZA') %>
            </span>
            <span style="color:var(--ink-muted);"> vs last month</span>
          </div>
          <% } %>
        </div>
      </div>

    </div>

    <!-- Quick actions row -->
    <div class="grid-3" style="margin-top:1.5rem;margin-bottom:0;">
      <a href="/admin/bookings" class="quick-action-card">
        <div class="quick-action-icon" style="background:linear-gradient(135deg,var(--primary),var(--primary-light));">
          <svg viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="26" height="26"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
        </div>
        <h4>Manage Bookings</h4>
        <p>Review and update booking statuses</p>
      </a>
      <a href="/admin/results" class="quick-action-card">
        <div class="quick-action-icon" style="background:linear-gradient(135deg,#e17055,#fd79a8);">
          <svg viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="26" height="26"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
        </div>
        <h4>Upload Results</h4>
        <p>Add screening documents</p>
      </a>
      <a href="/admin/certificates" class="quick-action-card">
        <div class="quick-action-icon" style="background:linear-gradient(135deg,#0b6e4f,#00b894);">
          <svg viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="26" height="26"><circle cx="12" cy="8" r="6"/><path d="M15.477 12.89L17 22l-5-3-5 3 1.523-9.11"/></svg>
        </div>
        <h4>Issue Certificates</h4>
        <p>Generate occupational health certs</p>
      </a>
    </div>
  </div>
</main>
</div>
<script src="/js/main.js?v=<%= locals.assetVersion %>"></script>
</body>
</html>
