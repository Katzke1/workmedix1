<%- include('../partials/head') %>
<meta name="csrf-token" content="<%= csrfToken %>">
<body>
<div class="app-body">
<%- include('../partials/admin-sidebar') %>
<main class="app-main">
  <div class="app-topbar">
    <div class="app-topbar-title">
      <h2>Scan In</h2>
      <p>Register screening patients on-site</p>
    </div>
    <div class="topbar-actions">
      <a href="/admin/medicals" class="btn btn-outline-dark btn-sm">View Medicals</a>
    </div>
  </div>

  <div class="app-content">
    <div class="scan-page"
         data-dl="<%= dlAvailable ? '1' : '0' %>"
         data-companies='<%- JSON.stringify(companies) %>'
         data-services='<%- JSON.stringify(services) %>'>

      <div id="msg" class="alert" style="display:none;" role="status" aria-live="polite"></div>

      <!-- ── 1. Session setup ─────────────────────────────────────────── -->
      <section id="sessionSetup" class="card scan-card">
        <div class="card-header"><h3>Start a screening session</h3></div>
        <div class="scan-card-body">
          <p class="scan-hint">Pick who you're screening today. Everyone you scan is added to this company &amp; site.</p>

          <label class="scan-label" for="companySel">Company <span class="req">*</span></label>
          <select id="companySel" class="form-control"><option value="">Select company…</option></select>

          <label class="scan-label" for="siteSel">Site / location</label>
          <select id="siteSel" class="form-control" disabled><option value="">— (optional) —</option></select>

          <label class="scan-label" for="serviceSel">Service</label>
          <select id="serviceSel" class="form-control"><option value="">On-site Screening</option></select>

          <label class="scan-consent">
            <input type="checkbox" id="consent">
            <span>I confirm each person consents to their ID being captured for this occupational screening (POPIA). See our <a href="/privacy" target="_blank" rel="noopener">privacy notice</a>.</span>
          </label>

          <button id="startBtn" class="btn btn-primary scan-btn-lg" disabled>Start session</button>
        </div>
      </section>

      <!-- ── 2. Active session ────────────────────────────────────────── -->
      <section id="sessionActive" style="display:none;">
        <div class="scan-sessbar">
          <div>
            <div class="scan-sessbar-co" id="sessCompany">—</div>
            <div class="scan-sessbar-sub"><span id="sessService">—</span> · <strong id="count">0</strong> scanned</div>
          </div>
          <button id="newSessionBtn" class="btn btn-outline-dark btn-sm" type="button">End</button>
        </div>

        <!-- Scan / capture -->
        <div class="card scan-card">
          <div class="scan-card-body">
            <button id="scanBtn" class="btn btn-primary scan-btn-lg" type="button">
              <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="vertical-align:-4px;margin-right:.4rem;"><path d="M3 7V5a2 2 0 0 1 2-2h2"/><path d="M17 3h2a2 2 0 0 1 2 2v2"/><path d="M21 17v2a2 2 0 0 1-2 2h-2"/><path d="M7 21H5a2 2 0 0 1-2-2v-2"/><line x1="7" y1="12" x2="17" y2="12"/></svg>
              Scan ID / Licence
            </button>
            <p class="scan-dl-note" id="dlNote"></p>

            <!-- Live camera -->
            <div id="cam" class="scan-cam" style="display:none;">
              <video id="camVideo" playsinline muted></video>
              <div class="scan-cam-frame"></div>
              <button id="camClose" class="scan-cam-close" type="button" aria-label="Close camera">✕</button>
              <div id="camStatus" class="scan-cam-status">Point at the barcode on the ID or licence…</div>
            </div>

            <div class="scan-or"><span>or enter details</span></div>

            <!-- Capture form (also the confirm screen after a scan) -->
            <form id="captureForm" autocomplete="off">
              <label class="scan-label" for="idNumber">SA ID number</label>
              <input id="idNumber" class="form-control" inputmode="numeric" maxlength="13" placeholder="13 digits">
              <div id="derived" class="scan-derived" style="display:none;"></div>

              <div class="scan-row">
                <div>
                  <label class="scan-label" for="firstName">First name <span class="req">*</span></label>
                  <input id="firstName" class="form-control" placeholder="First name">
                </div>
                <div>
                  <label class="scan-label" for="lastName">Surname <span class="req">*</span></label>
                  <input id="lastName" class="form-control" placeholder="Surname">
                </div>
              </div>

              <div class="scan-row">
                <div>
                  <label class="scan-label" for="genderSel">Gender</label>
                  <select id="genderSel" class="form-control">
                    <option value="">—</option><option>Male</option><option>Female</option>
                  </select>
                </div>
                <div>
                  <label class="scan-label" for="jobTitle">Job title</label>
                  <input id="jobTitle" class="form-control" placeholder="Optional">
                </div>
              </div>

              <button id="addBtn" class="btn btn-primary scan-btn-lg" type="submit">Add person</button>
            </form>
          </div>
        </div>

        <!-- Running list -->
        <div class="card scan-card">
          <div class="card-header"><h3>Scanned this session (<span id="listCount">0</span>)</h3></div>
          <ul id="peopleList" class="scan-list"></ul>
          <div id="listEmpty" class="scan-empty">No one scanned yet. Scan or add your first person above.</div>
        </div>
      </section>

    </div>
  </div>
</main>
</div>

<style>
  .scan-page { max-width: 560px; margin: 0 auto; }
  .scan-card { margin-bottom: 1rem; }
  .scan-card-body { padding: 1.1rem 1.15rem 1.25rem; }
  .scan-hint { font-size: .88rem; color: var(--ink-muted); margin: 0 0 1rem; line-height: 1.5; }
  .scan-label { display:block; font-size:.78rem; font-weight:600; color: var(--heading); margin:.85rem 0 .3rem; }
  .scan-label:first-of-type { margin-top: 0; }
  .scan-label .req { color: var(--danger); }
  .scan-page .form-control { width: 100%; font-size: 1rem; padding: .7rem .8rem; }
  .scan-page select.form-control { height: 46px; }
  #idNumber { font-size: 1.35rem; letter-spacing: .12em; font-variant-numeric: tabular-nums; font-weight: 600; }
  .scan-row { display: grid; grid-template-columns: 1fr 1fr; gap: .6rem; }
  .scan-btn-lg { width: 100%; padding: .85rem 1rem; font-size: 1rem; margin-top: 1.1rem; }
  .scan-consent { display:flex; gap:.55rem; align-items:flex-start; margin-top:1rem; font-size:.82rem; color:var(--ink-muted); line-height:1.45; cursor:pointer; }
  .scan-consent input { margin-top:.15rem; width:18px; height:18px; flex-shrink:0; accent-color: var(--primary); }
  .scan-sessbar { display:flex; align-items:center; justify-content:space-between; gap:1rem;
    background: var(--hero-ink); color:#fff; border-radius: var(--radius-lg); padding: .85rem 1.1rem; margin-bottom:1rem; }
  .scan-sessbar-co { font-weight: 700; font-size: 1rem; }
  .scan-sessbar-sub { font-size: .8rem; color: rgba(255,255,255,.7); margin-top:.15rem; }
  .scan-sessbar-sub strong { color:#fff; }
  .scan-dl-note { font-size:.76rem; color:var(--ink-muted); margin:.6rem 0 0; text-align:center; }
  .scan-or { display:flex; align-items:center; text-align:center; color:var(--ink-muted); font-size:.78rem; margin:1.2rem 0 .2rem; }
  .scan-or::before, .scan-or::after { content:''; flex:1; height:1px; background:var(--border); }
  .scan-or span { padding:0 .8rem; text-transform:uppercase; letter-spacing:.06em; }
  .scan-derived { margin-top:.5rem; font-size:.82rem; font-weight:600; color:var(--success-color); background:var(--success-bg); border-radius:var(--radius); padding:.5rem .7rem; }
  .scan-derived.bad { color:var(--danger-color); background:var(--danger-bg); }
  .scan-cam { position:relative; margin-top:1rem; border-radius:var(--radius-lg); overflow:hidden; background:#000; aspect-ratio: 4/3; }
  .scan-cam video { width:100%; height:100%; object-fit:cover; display:block; }
  .scan-cam-frame { position:absolute; inset:14% 10%; border:3px solid rgba(255,255,255,.85); border-radius:12px; box-shadow:0 0 0 100vmax rgba(0,0,0,.35); }
  .scan-cam-close { position:absolute; top:.5rem; right:.5rem; width:36px; height:36px; border:none; border-radius:50%; background:rgba(0,0,0,.55); color:#fff; font-size:1rem; cursor:pointer; }
  .scan-cam-status { position:absolute; left:0; right:0; bottom:0; padding:.6rem .8rem; background:rgba(0,0,0,.6); color:#fff; font-size:.82rem; text-align:center; }
  .scan-list { list-style:none; margin:0; padding:0; }
  .scan-list li { display:flex; align-items:center; gap:.7rem; padding:.7rem 1.15rem; border-top:1px solid var(--border); }
  .scan-list li:first-child { border-top:none; }
  .scan-list .av { width:34px;height:34px;border-radius:50%;background:var(--primary);color:#fff;display:flex;align-items:center;justify-content:center;font-weight:700;font-size:.85rem;flex-shrink:0; }
  .scan-list .nm { font-weight:600; color:var(--heading); }
  .scan-list .meta { font-size:.78rem; color:var(--ink-muted); }
  .scan-list .zap { margin-left:auto; font-size:.72rem; color:var(--success-color); font-weight:700; white-space:nowrap; }
  .scan-empty { padding:1.4rem 1.15rem; text-align:center; color:var(--ink-muted); font-size:.85rem; }
  @media (max-width: 480px) { .scan-row { grid-template-columns: 1fr; } }
</style>
<script src="/js/scan.js?v=<%= locals.assetVersion %>"></script>
</body>
</html>
