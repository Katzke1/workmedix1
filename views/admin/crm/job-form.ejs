<%- include('../../partials/head') %>
<body class="app-body">
<%- include('../../partials/admin-sidebar') %>
<div class="app-main">
  <div class="app-topbar">
    <div class="app-topbar-title"><h2>New Job</h2><p>Create a new job / visit</p></div>
    <a href="/admin/crm/jobs" class="btn btn-outline-dark btn-sm">← Back</a>
  </div>
  <div class="app-content">
    <div class="crm-detail-grid">
      <div class="card" style="grid-column:1/-1;max-width:780px">
        <div class="card-body">
          <% if (error) { %><div class="alert alert-danger"><%= error %></div><% } %>
          <form method="POST" action="/admin/crm/jobs" id="job-form">
            <div class="form-row">
              <div class="form-group">
                <label class="form-label">Client *</label>
                <select name="client_id" class="form-control" required>
                  <option value="">— select client —</option>
                  <% clients.forEach(c => { %><option value="<%= c.id %>" <%= (job?.client_id||preClient)==c.id?'selected':'' %>><%= c.company_name %></option><% }); %>
                </select>
              </div>
              <div class="form-group">
                <label class="form-label">Assigned Staff</label>
                <select name="staff_id" class="form-control">
                  <option value="">— none —</option>
                  <% staff.forEach(s => { %><option value="<%= s.id %>" <%= job?.staff_id==s.id?'selected':'' %>><%= s.name %></option><% }); %>
                </select>
              </div>
            </div>
            <div class="form-row">
              <div class="form-group">
                <label class="form-label">Service Type *</label>
                <select name="service_type" id="service-select" class="form-control" required>
                  <option value="">— select service —</option>
                  <% rates.forEach(r => { %><option value="<%= r.service_name %>" <%= job?.service_type===r.service_name?'selected':'' %>><%= r.service_name %></option><% }); %>
                </select>
              </div>
              <div class="form-group">
                <label class="form-label">Job Date *</label>
                <input type="date" name="job_date" class="form-control" required value="<%= job?.job_date || new Date().toISOString().slice(0,10) %>">
              </div>
            </div>

            <div class="form-row">
              <div class="form-group">
                <label class="form-label">Number of People *</label>
                <input type="number" name="num_people" id="num-people" class="form-control" min="1" value="<%= job?.num_people||1 %>" required>
              </div>
              <div class="form-group">
                <label class="form-label">Status</label>
                <select name="status" class="form-control">
                  <% ['quoted','confirmed','in_progress','completed','invoiced','paid','cancelled'].forEach(s => { %>
                    <option value="<%= s %>" <%= (job?.status||'quoted')===s?'selected':'' %>>
                      <%= {quoted:'Quoted',confirmed:'Confirmed',in_progress:'In Progress',completed:'Completed',invoiced:'Invoiced',paid:'Paid',cancelled:'Cancelled'}[s] %>
                    </option>
                  <% }); %>
                </select>
              </div>
            </div>

            <div class="form-row">
              <div class="form-group">
                <label class="form-label">Unit Price (per person, excl VAT)</label>
                <div class="input-group-prefix">
                  <span>R</span>
                  <input type="number" name="unit_price" id="unit-price" class="form-control" min="0" step="0.01" value="<%= job?.unit_price||'' %>" placeholder="auto-filled from rates">
                </div>
              </div>
              <div class="form-group">
                <label class="form-label">Unit Cost (per person, incl VAT)</label>
                <div class="input-group-prefix">
                  <span>R</span>
                  <input type="number" name="unit_cost" id="unit-cost" class="form-control" min="0" step="0.01" value="<%= job?.unit_cost||'' %>" placeholder="auto-filled from rates">
                </div>
              </div>
            </div>

            <div class="form-row">
              <div class="form-group">
                <label class="form-label">Travel Cost (flat fee)</label>
                <div class="input-group-prefix">
                  <span>R</span>
                  <input type="number" name="travel_cost" class="form-control" min="0" step="0.01" value="<%= job?.travel_cost||0 %>">
                </div>
              </div>
              <div class="form-group">
                <label class="form-label">Invoice Number</label>
                <input type="text" name="invoice_number" class="form-control" value="<%= job?.invoice_number||'' %>" placeholder="e.g. INV-001">
              </div>
            </div>

            <!-- Live profit preview -->
            <div class="crm-profit-preview" id="profit-preview" style="display:none">
              <div><span>Revenue</span><strong id="prev-rev">R 0</strong></div>
              <div><span>Cost</span><strong id="prev-cost" style="color:#ef4444">R 0</strong></div>
              <div style="border-top:1px solid rgba(255,255,255,.3);padding-top:.5rem"><span>Profit</span><strong id="prev-profit" style="color:#26de81">R 0</strong></div>
              <div><span>Margin</span><strong id="prev-margin" style="color:#26de81">0%</strong></div>
            </div>

            <div class="form-group">
              <label class="form-label">Notes</label>
              <textarea name="notes" class="form-control" rows="2"><%= job?.notes||'' %></textarea>
            </div>

            <div style="display:flex;gap:.75rem">
              <button type="submit" class="btn btn-primary">Save Job</button>
              <a href="/admin/crm/jobs" class="btn btn-outline-dark">Cancel</a>
            </div>
          </form>
        </div>
      </div>
    </div>
  </div>
</div>
<script>
const rateMap = {};
<% rates.forEach(r => { %>rateMap["<%= r.service_name.replace(/"/g,'&quot;') %>"] = { price: <%= r.default_price %>, cost: <%= r.default_cost %> };<% }); %>

const svcSel    = document.getElementById('service-select');
const priceIn   = document.getElementById('unit-price');
const costIn    = document.getElementById('unit-cost');
const numIn     = document.getElementById('num-people');
const preview   = document.getElementById('profit-preview');

function updatePreview() {
  const n = +numIn.value||1;
  const p = +priceIn.value||0;
  const c = +costIn.value||0;
  const t = +(document.querySelector('[name=travel_cost]').value)||0;
  const rev  = p * n;
  const cost = c * n + t;
  const prof = rev - cost;
  if (rev > 0 || cost > 0) {
    preview.style.display = 'flex';
    document.getElementById('prev-rev').textContent    = 'R ' + rev.toLocaleString('en-ZA', {minimumFractionDigits:2});
    document.getElementById('prev-cost').textContent   = 'R ' + cost.toLocaleString('en-ZA', {minimumFractionDigits:2});
    document.getElementById('prev-profit').textContent = 'R ' + prof.toLocaleString('en-ZA', {minimumFractionDigits:2});
    document.getElementById('prev-margin').textContent = rev > 0 ? (prof/rev*100).toFixed(1)+'%' : '—';
    document.getElementById('prev-profit').style.color = prof >= 0 ? '#26de81' : '#ef4444';
  }
}

svcSel.addEventListener('change', function() {
  const r = rateMap[this.value];
  if (r) { priceIn.value = r.price; costIn.value = r.cost; }
  updatePreview();
});
[priceIn, costIn, numIn].forEach(el => el.addEventListener('input', updatePreview));
document.querySelector('[name=travel_cost]').addEventListener('input', updatePreview);
updatePreview();
</script>
</body></html>
