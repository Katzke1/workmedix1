<%- include('../partials/head') %>
<body>
<div class="app-body">
<%- include('../partials/admin-sidebar') %>
<main class="app-main">
  <div class="app-topbar">
    <div class="app-topbar-title">
      <h2>Booking #<%= booking.id %></h2>
      <p><%= booking.service_type %> — <span class="badge badge-<%= booking.status %>"><%= booking.status %></span></p>
    </div>
    <div class="topbar-actions">
      <a href="/admin/bookings" class="btn btn-outline-dark btn-sm">← All Bookings</a>
    </div>
  </div>

  <div class="app-content">
    <% if (locals.success) { %><div class="alert alert-success" data-autodismiss><%= success %></div><% } %>
    <% if (locals.error)   { %><div class="alert alert-danger"><%= error %></div><% } %>

    <div style="display:grid;grid-template-columns:1fr 340px;gap:1.5rem;align-items:start;">

      <!-- Left column -->
      <div>
        <!-- Booking details card -->
        <div class="card" style="margin-bottom:1.5rem;">
          <div class="card-header"><h3>Booking Details</h3></div>
          <div class="card-body">
            <dl class="detail-list">
              <dt>Client</dt><dd><%= booking.client_name %> (<%= booking.client_email %>)</dd>
              <dt>Company</dt><dd><%= booking.company_name || booking.legacy_company_name || '—' %></dd>
              <dt>Service</dt><dd><%= booking.service_type %></dd>
              <dt>Preferred Date</dt><dd><%= booking.preferred_date || '—' %></dd>
              <% if (booking.scheduled_at) { %>
              <dt>Confirmed Time</dt><dd><%= new Date(booking.scheduled_at).toLocaleString('en-ZA') %></dd>
              <% } %>
              <dt>Location</dt>
              <dd>
                <% if (booking.site_label) { %>
                  <strong><%= booking.site_label %></strong><br>
                  <span style="font-size:.88rem;color:var(--ink-muted);">
                    <%= booking.site_address %><% if (booking.site_city) { %>, <%= booking.site_city %><% } %>
                  </span>
                <% } else { %>—<% } %>
              </dd>
              <dt>Assigned Practitioner</dt><dd><%= booking.staff_name || '—' %></dd>
              <dt>Notes</dt><dd><%= booking.notes || '—' %></dd>
              <dt>Submitted</dt><dd><%= new Date(booking.created_at).toLocaleString('en-ZA') %></dd>
            </dl>
          </div>
        </div>

        <!-- Attendees / employees -->
        <div class="card" style="margin-bottom:1.5rem;">
          <div class="card-header">
            <h3>Attendees (<%= booking.employees.length %>)</h3>
          </div>
          <% if (booking.employees.length === 0) { %>
            <%- include('../partials/empty-state', { title: 'No employees assigned', desc: 'Employees were not selected during booking or have not been assigned yet.', ctaHref: null }) %>
          <% } else { %>
          <div class="table-wrap">
            <table>
              <thead>
                <tr>
                  <th>Name</th><th>ID Number</th><th>Job Title</th><th>Attendance</th>
                </tr>
              </thead>
              <tbody>
                <% booking.employees.forEach(emp => { %>
                <tr>
                  <td><strong><%= emp.first_name %> <%= emp.last_name %></strong></td>
                  <td><%= emp.id_number || '—' %></td>
                  <td><%= emp.job_title || '—' %></td>
                  <td>
                    <form method="POST" action="/admin/bookings/<%= booking.id %>/attendance/<%= emp.id %>">
                      <%- include('../partials/csrf') %>
                      <select name="attendance_status" class="form-control" style="width:140px;" onchange="this.form.submit()">
                        <option value="scheduled" <%= emp.attendance_status==='scheduled' ? 'selected':'' %>>Scheduled</option>
                        <option value="attended"  <%= emp.attendance_status==='attended'  ? 'selected':'' %>>Attended</option>
                        <option value="no_show"   <%= emp.attendance_status==='no_show'   ? 'selected':'' %>>No Show</option>
                        <option value="rescheduled" <%= emp.attendance_status==='rescheduled' ? 'selected':'' %>>Rescheduled</option>
                      </select>
                    </form>
                  </td>
                </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
          <% } %>
        </div>

        <!-- Create CRM job (visible when completed) -->
        <% if (booking.status === 'completed' && !booking.crm_job_id) { %>
        <div class="card" style="border-left:3px solid var(--accent);">
          <div class="card-body" style="display:flex;align-items:center;justify-content:space-between;gap:1rem;">
            <div>
              <strong>Ready to invoice?</strong>
              <p style="margin:0;font-size:.88rem;color:var(--ink-muted);">Create a CRM job from this booking to track revenue and issue an invoice.</p>
            </div>
            <form method="POST" action="/admin/bookings/<%= booking.id %>/create-crm-job">
              <%- include('../partials/csrf') %>
              <button type="submit" class="btn btn-primary btn-sm">Create CRM Job →</button>
            </form>
          </div>
        </div>
        <% } %>
        <% if (booking.crm_job_id) { %>
        <div class="card" style="border-left:3px solid #10B981;">
          <div class="card-body">
            <strong style="color:#10B981;">CRM Job created</strong> —
            <a href="/admin/crm/jobs/<%= booking.crm_job_id %>">View Job #<%= booking.crm_job_id %> →</a>
          </div>
        </div>
        <% } %>
      </div>

      <!-- Right column -->
      <div>
        <!-- Status control -->
        <div class="card" style="margin-bottom:1.25rem;">
          <div class="card-header"><h3>Status</h3></div>
          <div class="card-body">
            <form method="POST" action="/admin/bookings/<%= booking.id %>/status">
              <%- include('../partials/csrf') %>
              <div class="form-group">
                <label class="form-label">Booking Status</label>
                <select name="status" class="form-control">
                  <option value="pending"     <%= booking.status==='pending'     ? 'selected':'' %>>Pending</option>
                  <option value="confirmed"   <%= booking.status==='confirmed'   ? 'selected':'' %>>Confirmed</option>
                  <option value="in_progress" <%= booking.status==='in_progress' ? 'selected':'' %>>In Progress</option>
                  <option value="completed"   <%= booking.status==='completed'   ? 'selected':'' %>>Completed</option>
                  <option value="cancelled"   <%= booking.status==='cancelled'   ? 'selected':'' %>>Cancelled</option>
                </select>
              </div>
              <div class="form-group" id="cancel-reason-group" style="display:<%= booking.status==='cancelled'?'block':'none' %>;">
                <label class="form-label">Cancellation Reason</label>
                <textarea name="cancellation_reason" class="form-control" rows="2"><%= booking.cancellation_reason || '' %></textarea>
              </div>
              <button type="submit" class="btn btn-primary btn-sm" style="width:100%;">Update Status</button>
            </form>
          </div>
        </div>

        <!-- Staff assignment -->
        <div class="card" style="margin-bottom:1.25rem;">
          <div class="card-header"><h3>Assign Practitioner</h3></div>
          <div class="card-body">
            <form method="POST" action="/admin/bookings/<%= booking.id %>/assign-staff">
              <%- include('../partials/csrf') %>
              <div class="form-group">
                <label class="form-label">Staff Member</label>
                <select name="staff_id" class="form-control">
                  <option value="">— Unassigned —</option>
                  <% staffList.forEach(s => { %>
                  <option value="<%= s.id %>" <%= booking.staff_id===s.id ? 'selected':'' %>><%= s.name %></option>
                  <% }) %>
                </select>
              </div>
              <div class="form-group">
                <label class="form-label">Confirmed Date &amp; Time</label>
                <input type="datetime-local" name="scheduled_at" class="form-control"
                       value="<%= booking.scheduled_at ? booking.scheduled_at.replace(' ','T').substring(0,16) : '' %>">
              </div>
              <button type="submit" class="btn btn-outline-dark btn-sm" style="width:100%;">Save Assignment</button>
            </form>
          </div>
        </div>

        <!-- Quick links -->
        <div class="card">
          <div class="card-body" style="display:flex;flex-direction:column;gap:.5rem;">
            <a href="/admin/results" class="btn btn-outline-dark btn-sm">Upload Results</a>
            <a href="/admin/certificates" class="btn btn-outline-dark btn-sm">Issue Certificate</a>
          </div>
        </div>
      </div>
    </div>
  </div>
</main>
</div>
<style>
.detail-list { display:grid; grid-template-columns:140px 1fr; gap:.35rem 1rem; font-size:.92rem; }
.detail-list dt { font-weight:600; color:var(--ink-muted); white-space:nowrap; }
.detail-list dd { margin:0; color:var(--ink); }
</style>
<script>
document.querySelector('[name="status"]')?.addEventListener('change', function() {
  document.getElementById('cancel-reason-group').style.display = this.value === 'cancelled' ? 'block' : 'none';
});
</script>
<script src="/js/main.js"></script>
</body>
</html>
