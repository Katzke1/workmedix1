<%- include('../partials/head') %>
<body>
<div class="auth-page">
  <!-- Left panel -->
  <div class="auth-left">
    <div class="auth-left-content">
      <a href="/" class="auth-logo">
        <img src="/images/logo.jpg" alt="Workmedix" onerror="this.style.display='none'">
        <span>Workmedix</span>
      </a>
      <h2>Welcome back.</h2>
      <p>Sign in to access your screening results, certificates, and booking history through the Workmedix client portal.</p>
      <div style="margin-top:2.5rem;padding:1.5rem;background:rgba(255,255,255,.07);border-radius:12px;border:1px solid rgba(255,255,255,.12);">
        <p style="color:rgba(255,255,255,.55);font-size:.82rem;margin-bottom:.75rem;font-weight:600;letter-spacing:.06em;text-transform:uppercase;">New to Workmedix?</p>
        <p style="color:rgba(255,255,255,.75);font-size:.9rem;margin-bottom:1rem;">Create a free account to book screenings and track your results online.</p>
        <a href="/register" class="btn btn-outline" style="font-size:.88rem;padding:.55rem 1.25rem;">Create Account</a>
      </div>
    </div>
    <div class="auth-left-footer">&copy; 2025 Workmedix. All rights reserved.</div>
  </div>

  <!-- Right panel -->
  <div class="auth-right">
    <div class="auth-card">
      <h2>Sign In</h2>
      <p class="sub">Enter your credentials to continue.</p>

      <% if (error) { %>
        <div class="alert alert-danger"><%= error %></div>
      <% } %>

      <form method="POST" action="/login" novalidate>
        <div class="form-group">
          <label class="form-label" for="email">Email Address</label>
          <input type="email" id="email" name="email" class="form-control"
                 placeholder="you@company.co.za" required autocomplete="email">
        </div>
        <div class="form-group">
          <label class="form-label" for="password">Password</label>
          <div class="input-password-wrap">
            <input type="password" id="password" name="password" class="form-control"
                   placeholder="••••••••" required autocomplete="current-password">
            <button type="button" class="password-toggle" data-target="password" tabindex="-1">
              <svg class="eye-show" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="16" height="16"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
              <svg class="eye-hide" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="16" height="16" style="display:none"><path d="M17.94 17.94A10.07 10.07 0 0112 20c-7 0-11-8-11-8a18.45 18.45 0 015.06-5.94M9.9 4.24A9.12 9.12 0 0112 4c7 0 11 8 11 8a18.5 18.5 0 01-2.16 3.19m-6.72-1.07a3 3 0 11-4.24-4.24"/><line x1="1" y1="1" x2="23" y2="23"/></svg>
            </button>
          </div>
        </div>
        <button type="submit" class="btn btn-primary btn-block" style="margin-top:.5rem;" id="login-btn">
          Sign In →
        </button>
      </form>

      <div class="auth-footer">
        Don't have an account? <a href="/register">Register here</a>
      </div>
      <div style="text-align:center;margin-top:.75rem;">
        <a href="/" style="font-size:.82rem;color:var(--mid-grey);">&larr; Back to website</a>
      </div>
    </div>
  </div>
</div>
<script src="/js/main.js"></script>
</body>
</html>
