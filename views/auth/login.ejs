<%- include('../partials/head') %>
<body>
<div class="auth-page">

  <!-- Left panel — dark navy brand -->
  <div class="auth-left">
    <div class="auth-left-content">
      <a href="/" class="auth-logo">
        <img src="/images/logo-white.png" alt="Workmedix">
      </a>
      <h2>Welcome back.</h2>
      <p>Sign in to access your screening results, certificates, and booking history through the Workmedix client portal.</p>
      <div style="margin-top:2.5rem;padding:1.5rem;background:rgba(255,255,255,.07);border-radius:12px;border:1px solid rgba(255,255,255,.12);">
        <p style="color:rgba(255,255,255,.55);font-size:.82rem;margin-bottom:.75rem;font-weight:600;letter-spacing:.06em;text-transform:uppercase;">New to Workmedix?</p>
        <p style="color:rgba(255,255,255,.75);font-size:.9rem;margin-bottom:1rem;">Create a free account to book screenings and track your results online.</p>
        <a href="/register" class="btn btn-outline" style="font-size:.88rem;padding:.55rem 1.25rem;">Create Account</a>
      </div>
    </div>
    <div class="auth-left-footer">&copy; <%= new Date().getFullYear() %> Workmedix. All rights reserved.</div>
  </div>

  <!-- Right panel — white form -->
  <div class="auth-right">
    <div class="auth-card">
      <h2>Sign In</h2>
      <p class="sub">Enter your credentials to continue.</p>

      <% if (locals.msg === 'verify') { %>
        <div class="alert alert-success">
          ✓ Account created! Check your inbox for a verification link and click it to activate your account before signing in.
        </div>
      <% } %>
      <% if (locals.msg === 'contact') { %>
        <div class="alert alert-success">✓ Message sent! Our team will be in touch within one business day.</div>
      <% } %>
      <% if (locals.msg === 'reset') { %>
        <div class="alert alert-success">✓ Password updated successfully. Please sign in with your new password.</div>
      <% } %>
      <% if (error) { %>
        <div class="alert alert-danger">
          <%= error %>
          <% if (locals.resendEmail) { %>
            <br><a href="/resend-verification?email=<%= encodeURIComponent(resendEmail) %>"
                   style="color:inherit;font-weight:700;text-decoration:underline;">
              Resend verification email →
            </a>
          <% } %>
        </div>
      <% } %>

      <form method="POST" action="/login" novalidate>
        <%- include('../partials/csrf') %>
        <div class="form-group">
          <label class="form-label" for="email">Email Address</label>
          <input type="email" id="email" name="email" class="form-control"
                 placeholder="you@company.co.za" required autocomplete="email">
        </div>
        <div class="form-group">
          <label class="form-label" for="password" style="display:flex;justify-content:space-between;align-items:center;">
            Password
            <a href="/forgot-password" style="font-size:.82rem;font-weight:500;color:var(--primary);">Forgot password?</a>
          </label>
          <input type="password" id="password" name="password" class="form-control"
                 placeholder="••••••••" required autocomplete="current-password">
        </div>
        <button type="submit" class="btn btn-primary btn-block" style="margin-top:.5rem;">
          Sign In →
        </button>
      </form>

      <div class="auth-footer">
        Don't have an account? <a href="/register">Register here</a>
      </div>
      <div style="text-align:center;margin-top:.75rem;">
        <a href="/" style="font-size:.82rem;color:var(--mid-grey);">&larr; Back to website</a>
      </div>
    </div>
  </div>

</div>
<script src="/js/main.js"></script>
</body>
</html>
